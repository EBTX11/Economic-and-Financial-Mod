				}

				blockoverride "before_bar_icon" {}

				blockoverride "progressbar_size" {
					size = { 150 15 }
				}

				blockoverride "before_bar_text_visibility" {
					visible = no
				}

				blockoverride "above_bar_text_visibility" {
					visible = yes
				}

				blockoverride "above_bar_text_size" {
					size = { 45 20 }
				}

				blockoverride "above_bar_text" {
					text = "LAW_INDIFFERENT"
				}

				blockoverride "bar_value" {
					value = "[Law.GetPercentPolStrUndecided]"
					invertprogress = yes
				}

				blockoverride "marker_visibility" {
					visible = "[NotZero_CFixedPoint(Law.GetPercentPolStrUndecided)]"
				}

				blockoverride "marker_widgetanchor" {
					widgetanchor = left
					mirror = horizontal
				}

				blockoverride "bar_color" {
					using = color_grey_undecided
				}
			}
		}

		flowcontainer = {
			direction = vertical
			datamodel = "[Law.AccessNeutralIGs]"

			item = {
				container = {
					negotiate_interest_group_button = {
						visible = "[Not(Or(InterestGroup.HasNegotiated, InterestGroup.IsNegotiating))]"
					}

					negotiate_interest_group_active_widget = {
						visible = "[Or(InterestGroup.HasNegotiated, InterestGroup.IsNegotiating)]"
					}
				}
			}
		}

		widget = {
			size = { 5 10 }
		}

		flowcontainer = {
			margin_bottom = 2
			margin_right = 5
			spacing = 5

			background = {
				using = default_header_bg
				margin = { 10 5 }

				modify_texture = {
					texture = "gfx/interface/masks/fade_horizontal_center.dds"
					blend_mode = alphamultiply
				}
			}

			icon = {
				parentanchor = vcenter
				size = { 28 28 }
				texture = "gfx/interface/icons/generic_icons/disapproval_icon.dds"
			}

			textbox = {
				parentanchor = vcenter
				autoresize = yes
				minimumsize = { 262 -1 }
				max_width = 262
				default_format = "#header"
				align = nobaseline
				using = right_click_menu_title_margin_left
				using = elide_fontsize_min
				text = "OPPOSING_INTEREST_GROUPS_HEADER"
			}

			endorsement_info_bar = {
				blockoverride "tooltip" {
					using = tooltip_ne
					tooltip = "TOOLTIP_LAW_DISAPPROVAL"
				}

				blockoverride "before_bar_icon" {}

				blockoverride "progressbar_size" {
					size = { 150 15 }
				}

				blockoverride "before_bar_text_visibility" {
					visible = no
				}

				blockoverride "above_bar_text_visibility" {
					visible = yes
				}

				blockoverride "above_bar_text_size" {
					size = { 45 20 }
				}

				blockoverride "above_bar_text" {
					text = "LAW_DISAPPROVAL"
				}

				blockoverride "bar_value" {
					value = "[Law.GetPercentPolStrDisapprove]"
					invertprogress = yes
				}

				blockoverride "marker_visibility" {
					visible = "[NotZero_CFixedPoint(Law.GetPercentPolStrDisapprove)]"
				}

				blockoverride "marker_widgetanchor" {
					widgetanchor = left
					mirror = horizontal
				}

				blockoverride "bar_color" {
					using = color_red_disapproval
				}
			}
		}

		flowcontainer = {
			direction = vertical
			datamodel = "[Law.AccessDisapprovingIGs]"

			item = {
				container = {
					negotiate_interest_group_button = {
						visible = "[Not(Or(InterestGroup.HasNegotiated, InterestGroup.IsNegotiating))]"
					}

					negotiate_interest_group_active_widget = {
						visible = "[Or(InterestGroup.HasNegotiated, InterestGroup.IsNegotiating)]"
					}
				}
			}
		}

		widget = {
			size = { 5 10 }
		}

		widget = {
			layoutpolicy_vertical = preferred
			size = { 460 52 }

			hbox = {
				layoutpolicy_horizontal = preferred
				layoutpolicy_vertical = preferred
				margin = { 10 5 }
				spacing = 10
				tooltip = "TOOLTIP_LAW_APPROVAL"
				alpha = "[TransparentIfFalse(NotEqualTo_CFixedPoint( Law.GetPercentPolStrApprove, '(CFixedPoint)0' ))]"

				background = {
					using = entry_bg
				}

				icon = {
					size = { 28 28 }
					texture = "gfx/interface/icons/generic_icons/approval_icon.dds"
				}

				overlappingitembox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = preferred
					datamodel = "[Law.AccessApprovingIGs]"
					spacing = 10

					item = {
						ig_button = {
							size = { 40 40 }
							using = tooltip_se

							icon = {
								visible = "[Or(InterestGroup.HasNegotiated, InterestGroup.IsNegotiating)]"
								parentanchor = right
								position = { 5 -3 }
								size = { 25 25 }
								texture = "gfx/interface/backgrounds/rounded_bg.dds"

								icon = {
									parentanchor = center
									size = { 60% 60% }
									texture = "gfx/interface/icons/generic_icons/negotiate.dds"
								}
							}
						}
					}
				}

				expand = {}

				flowcontainer = {
					direction = vertical
					spacing = 5

					textbox = {
						parentanchor = right
						align = right|nobaseline
						text = "LAW_APPROVAL"
						autoresize = yes
					}

					bar_horizontal = {

						block "progressbar_size" {
							size = { 150 15 }
						}

						blockoverride "values" {
							min = 0
							max = 1
							value = "[Law.GetPercentPolStrApprove]"
							invertprogress = yes
						}

						blockoverride "marker_widgetanchor" {
							widgetanchor = left
							mirror = horizontal
						}

						blockoverride "marker_visibility" {
							visible = "[NotZero_CFixedPoint(Law.GetPercentPolStrApprove)]"
						}

						blockoverride "color" {
							using = color_green_approval
						}
					}
				}
			}
		}
	}
}

right_click_menu = {
	name = "army_movement_menu"
	parentanchor = right

	blockoverride "title_text" {
		text = "MOVE_MILITARY_FORMATION"
	}

	blockoverride "resizeparent_without_fixed_bottom" {}

	blockoverride "items" {

		flowcontainer = {
			direction = vertical

			### Station in State
			right_click_menu_item = {
				size = { 260 44 }
				tooltip = "STATION_MILITARY_FORMATION_TOOLTIP"

				blockoverride "button" {
					using = default_button_map_interaction
				}

				blockoverride "properties" {
					onclick = "[MilitaryFormation.OnStationClicked]"
					enabled = "[MilitaryFormation.CanStation]"
				}

				blockoverride "texture" {
					texture = "gfx/interface/icons/formation_order_icons/station_armies.dds"
				}

				blockoverride "text" {
					text = "STATION_MILITARY_FORMATION_LABEL"
				}

				action_selection_number = {
					blockoverride "text" {
						text = "[MilitaryFormation.GetNumStationSelections|+]"
					}
				}
			}

			### Deploy to Front
			right_click_menu_item = {
				size = { 260 44 }
				tooltip = "DEPLOY_MILITARY_FORMATION_TO_FRONT_TOOLTIP"

				blockoverride "button" {
					using = default_button_map_interaction
				}

				blockoverride "properties" {
					onclick = "[MilitaryFormation.OnDeployToFrontClicked]"
					enabled = "[And( MilitaryFormation.CanDeployToFront, MilitaryFormation.IsMobilized )]"
				}

				blockoverride "texture" {
					texture = "gfx/interface/icons/formation_order_icons/send_to_front.dds"
				}

				blockoverride "text" {
					text = "DEPLOY_MILITARY_FORMATION_TO_FRONT_TEXT"
				}

				action_selection_number = {
					blockoverride "text" {
						text = "[MilitaryFormation.GetNumDeployToFrontSelections|+]"
					}
				}
			}

			### Embark
			right_click_menu_item = {
				size = { 260 44 }
				visible = "[Not( MilitaryFormation.IsAttachedToFleet )]"
				tooltip = "MILITARY_FORMATION_EMBARK_TOOLTIP"

				blockoverride "button" {
					using = default_button_map_interaction
				}

				blockoverride "properties" {
					enabled = "[MilitaryFormation.CanEmbark]"
					onclick = "[RightClickMenuManager.ShowForEmbarkSelectFleet( MilitaryFormation.AccessSelf )]"
				}

				blockoverride "texture" {
					texture = "gfx/interface/icons/formation_order_icons/embark_onto_fleet.dds"
				}

				blockoverride "text" {
					text = "MILITARY_FORMATION_EMBARK_LABEL"
				}

				action_selection_number = {
					blockoverride "text" {
						text = "[MilitaryFormation.GetNumEmbarkSelections|+]"
					}
				}
			}

			### Disembark
			right_click_menu_item = {
				size = { 260 44 }
				visible = "[MilitaryFormation.IsAttachedToFleet]"
				tooltip = "MILITARY_FORMATION_DISEMBARK_TOOLTIP"

				blockoverride "button" {
					using = default_button_map_interaction
				}

				blockoverride "properties" {
					enabled = "[IsValid(MilitaryFormation.DisembarkFormation)]"
					onclick = "[Execute(MilitaryFormation.DisembarkFormation)]"
					onclick = "[RightClickMenuManager.Close]"
				}

				blockoverride "texture" {
					texture = "gfx/interface/icons/formation_order_icons/disembark_from_fleet.dds"
				}

				blockoverride "text" {
					text = "MILITARY_FORMATION_DISEMBARK_LABEL"
				}
			}

			### Rehome
			right_click_menu_item = {
				size = { 260 44 }
				tooltip = "REHOME_MILITARY_FORMATION_TOOLTIP"

				blockoverride "button" {
					using = default_button_map_interaction
				}

				blockoverride "properties" {
					enabled = "[MilitaryFormation.GetCountry.IsLocalPlayer]"
					onclick = "[MilitaryFormation.OnRehomeClicked]"
				}

				blockoverride "texture" {
					texture = "gfx/interface/icons/generic_icons/home_hq.dds"
				}

				blockoverride "text" {
					text = "REHOME_MILITARY_FORMATION_LABEL"
				}
			}
		}
	}
}

