			dynamicgridbox = {
				datamodel = "[MilitaryFormation.GetPotentialMissionsTypes]"

				item = {
					container = {
						naval_mission_right_click_item = {
							visible = "[MilitaryFormation.HasNavalMission]"

							blockoverride "naval_mission_tooltip" {
								tooltipwidget = {
									FancyTooltip_NavalMissionType = {
										blockoverride "naval_mission_tooltip_desc" {
											custom_tooltip_textbox = {
												visible = "[Not(StringIsEmpty(GetDesc(MilitaryFormation.CreateNavalMissionWithPreviousArea(NavalMissionType.AccessSelf))))]"
												text = "[GetDesc(MilitaryFormation.CreateNavalMissionWithPreviousArea(NavalMissionType.AccessSelf))]"
											}

											custom_tooltip_newline = {
												visible = "[Not(StringIsEmpty(GetDesc(MilitaryFormation.CreateNavalMissionWithPreviousArea(NavalMissionType.AccessSelf))))]"
											}
										}
									}
								}
							}

							blockoverride "not_selected_visibility" {
								visible = "[Not(MilitaryFormation.HasNavalMissionType(NavalMissionType.AccessSelf))]"
							}

							blockoverride "selected_visibility" {
								visible = "[MilitaryFormation.HasNavalMissionType(NavalMissionType.AccessSelf)]"
							}

							blockoverride "add_mission_button_properties" {
								enabled = "[IsValid(MilitaryFormation.CreateNavalMissionWithPreviousArea(NavalMissionType.AccessSelf))]"
								onclick = "[PopupManager.ExecuteOrAskConfirmationIfNeeded(MilitaryFormation.CreateNavalMissionWithPreviousArea(NavalMissionType.AccessSelf))]"
							}

							blockoverride "remove_mission_button_properties" {
								enabled = "[IsValid(MilitaryFormation.RemoveNavalMission)]"
								onclick = "[Execute(MilitaryFormation.RemoveNavalMission)]"
							}

							blockoverride "tooltip" {
								tooltipwidget = {
									FancyTooltip_NavalMissionType = {
										blockoverride "tooltip_content_after" {
											custom_tooltip_textbox = {
												text = "[GetDesc(MilitaryFormation.CreateNavalMissionWithPreviousArea(NavalMissionType.AccessSelf))]"
											}
										}
									}
								}
							}

							blockoverride "remove_naval_mission_tooltip" {
								tooltipwidget = {
									FancyTooltip_NavalMissionType = {
										blockoverride "text_before" {
											custom_tooltip_textbox_with_empty_line = {
												tooltip = "UNASSIGN_NAVAL_MISSION_TOOLTIP_FLEET"
											}
										}
									}
								}
							}
						}

						naval_mission_right_click_item = {
							visible = "[Not(MilitaryFormation.HasNavalMission)]"

							blockoverride "naval_mission_tooltip" {
								tooltipwidget = {
									FancyTooltip_NavalMissionType = {
										blockoverride "naval_mission_tooltip_desc" {
											custom_tooltip_textbox = {
												visible = "[Not(StringIsEmpty(GetDesc(MilitaryFormation.CreateNavalMission(NavalMissionType.AccessSelf))))]"
												text = "[GetDesc(MilitaryFormation.CreateNavalMission(NavalMissionType.AccessSelf))]"
											}

											custom_tooltip_newline = {
												visible = "[Not(StringIsEmpty(GetDesc(MilitaryFormation.CreateNavalMission(NavalMissionType.AccessSelf))))]"
											}
										}
									}
								}
							}

							blockoverride "not_selected_visibility" {
								visible = "[Not(MilitaryFormation.HasNavalMissionType(NavalMissionType.AccessSelf))]"
							}

							blockoverride "selected_visibility" {
								visible = "[MilitaryFormation.HasNavalMissionType(NavalMissionType.AccessSelf)]"
							}

							blockoverride "add_mission_button_properties" {
								enabled = "[IsValid(MilitaryFormation.CreateNavalMission(NavalMissionType.AccessSelf))]"
								onclick = "[PopupManager.ExecuteOrAskConfirmationIfNeeded(MilitaryFormation.CreateNavalMission(NavalMissionType.AccessSelf))]"
								onclick = "[MilitaryFormation.OnEditMissionSeaRegionsClicked]"
							}

							blockoverride "remove_mission_button_properties" {
								enabled = "[IsValid(MilitaryFormation.RemoveNavalMission)]"
								onclick = "[Execute(MilitaryFormation.RemoveNavalMission)]"
							}

							blockoverride "tooltip" {
								tooltipwidget = {
									FancyTooltip_NavalMissionType = {
										blockoverride "tooltip_content_after" {
											custom_tooltip_textbox = {
												text = "[GetDesc(MilitaryFormation.CreateNavalMission(NavalMissionType.AccessSelf))]"
											}
										}
									}
								}
							}

							blockoverride "remove_naval_mission_tooltip" {
								tooltipwidget = {
									FancyTooltip_NavalMissionType = {
										blockoverride "text_before" {
											custom_tooltip_textbox_with_empty_line = {
												tooltip = "UNASSIGN_NAVAL_MISSION_TOOLTIP_FLEET"
											}
										}
									}
								}
							}
						}
					}
				}
			}

			flowcontainer = {
				spacing = 10
				margin = { 20 10 }
				minimumsize = { 360 -1 }
				direction = vertical

				background = {
					using = entry_bg_simple
				}

				textbox = {
					parentanchor = hcenter
					autoresize = yes
					align = hcenter|nobaseline
					multiline = yes
					max_width = 320
					text = "FLEET_NAVAL_MISSION_REGIONS"
				}

				textbox = {
					visible = "[StringIsEmpty(MilitaryFormation.GetNavalMissionRegionsDesc)]"
					parentanchor = hcenter
					autoresize = yes
					align = hcenter|nobaseline
					multiline = yes
					max_width = 320
					text = "FLEET_HAS_NO_NAVAL_MISSION"
				}

				button = {
					parentanchor = hcenter
					size = { 320 50 }
					using = default_button_map_interaction
					enabled = "[MilitaryFormation.CanEditMissionSeaRegions]"
					onclick = "[MilitaryFormation.OnEditMissionSeaRegionsClicked]"
					tooltip = "EDIT_NAVAL_MISSION_SEA_REGIONS_TOOLTIP"

					hbox = {
						layoutpolicy_horizontal = expanding
						margin = { 10 5 }
						spacing = 5

						expand = {}

						textbox = {
							layoutpolicy_horizontal = expanding
							size = { 0 20 }
							align = hcenter|nobaseline
							elide = right
							fontsize_min = 12
							min_width = 52
							text = "CHANGE_REGION"
						}

						expand = {}
					}
				}
			}
		}
	}
}

