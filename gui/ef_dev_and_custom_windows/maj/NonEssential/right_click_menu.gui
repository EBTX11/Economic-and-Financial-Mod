types right_click_commander_items
{
	type right_click_commander_recruitment_item = right_click_menu_item {
		blockoverride "icon" {
			character_portrait_small_with_rank = {}
		}

		blockoverride "properties" {
			tooltip = "ASSIGN_COMMANDER_RECRUIT_TOOLTIP"
			enabled = "[IsValid(Character.GetRecruitCommand(MilitaryFormation.Self))]"
			onclick = "[Execute(Character.GetRecruitCommand(MilitaryFormation.Self))]"
			onclick = "[RightClickMenuManager.Close]"
		}

		blockoverride "text" {
			text = "ASSIGN_COMMANDER_CHARACTER_ENTRY"
		}

		blockoverride "rclick_item_after_label" {
			textbox = {
				autoresize = yes
				align = nobaseline|right
				fontsize_min = 12
				elide = right
				margin_right = 10
				raw_text = "#v [Character.GetCommandLimitRaw]#!"
			}
		}

		blockoverride "size" {
			size = { 360 44 }
		}
	}
}

template standard_formation_item_size {
	size = { 345 80 }
}

template right_click_menu_title_margin_left {
	margin_left = 3
}

