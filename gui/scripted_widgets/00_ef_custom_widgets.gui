#widget_je_ef_efcc_situation
flowcontainer = {
	name = "widget_je_ef_efcc_situation"
	ignoreinvisible = yes

	flowcontainer = {
		direction = vertical  
		spacing = 10

		flowcontainer = {
			parentanchor = hcenter
			direction = vertical
			margin_top = 10

			spacing = 15

			# Ces 5 evenement sripted effect:
			# currency_crisis
			# economic_crisis
			# financial_crash
			# country_bankruptcy
			# central_bank_bankruptcy

			# sont appeler à different endroit du code:

			# - currency_crisis -> appel
			# 	> fluctuations_money_value_1_year si la valeur de la monaie perd 50% en 1an
			# - economic_crisis -> appel
			# 	> fluctuations_gdp_1_year si la valeur du GDP perd 50% en 1an
			# - financial_crash -> appel
			# 	> fluctuations_country_indice_value_year si la valeur boursière perd 50% en 1an
			# - country_bankruptcy -> appel
			# 	> fluctuations_gdp_1_year -> spectre large du trigger -> déclanche si le pays a le declared_bankruptcy moddificateur
			# - central_bank_bankruptcy -> appel
			# 	#central_bank_bankruptcy -> spécial ....
 
			divider_decorative = { }

			flowcontainer = {
				direction = vertical
				parentanchor = hcenter

				spacing = 10

				#titre
				flowcontainer  = {
					margin_top = 0
					margin_right = 0
					margin_left = 0
					margin_bottom = 10

					spacing = 5

					direction = horizontal
					parentanchor = hcenter

					textbox = {
						autoresize = yes
						text = "current_situation"

						align = left|nobaseline
						elide = right
						default_format = "#l"
						autoresize = yes
						fontsize = 20
						allow_outside = yes
						ignoreinvisible = yes 
					}
				} 
				#status
				flowcontainer  = {
					#visible = "[GetScriptedGui('nothing_crisis').IsShown( GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
					margin_top = 0
					margin_right = 0
					margin_left = 0

					spacing = 25

					direction = vertical

					flowcontainer  = {
						margin_top = 0
						margin_right = 0
						margin_left = 0

						spacing = 25

						direction = horizontal
						parentanchor = hcenter
  
						#economic_instability
						flowcontainer = {
							spacing = 10
							direction = horizontal
 
							icon = { 
								size = { 60 60 }
								texture = "gfx/interface/icons/timed_modifier_icons/economic_instability.dds"
							}   

							widget = { 
								size = { 20 10 }  

								textbox = { 
									position = { 10 0 }
									autoresize = yes
									text = "economic_instability"
									align = left
									parentanchor = Vcenter
									fontsize = 25
									multiline = yes
									minimumsize = { 200 40 }
									maximumsize = { 200 -1 }
									default_format = "#white #bold"
								}  
								textbox = {  
									position = { 100 11 }
									autoresize = yes
									text = "[GetPlayer.GetCustom('economic_instability')]"
									align = left
									parentanchor = hcenter
									fontsize = 30
									default_format = "#white #bold" 
								} 
								textbox = {  
									position = { 76 52 }
									autoresize = yes
									text = "economic_instability_count"
									align = left
									parentanchor = Vcenter
									fontsize = 18
								}  
								# round_progress_bad = {  
								# 	position = { 210 15 }
								# 	size = { 300% 500% } 
									
								# 	value = "[GetPlayer.MakeScope.ScriptValue('money_value_dif_1_final')|%|=+]"   
								# }
							}     
 
							background = {
								using = entry_bg_simple
								margin = { 10 10 }
							}

							minimumsize = { 300 63 }
							maximumsize = { 300 -1 }
						}
					}
 
					flowcontainer  = {
						margin_top = 0
						margin_right = 0
						margin_left = 0

						spacing = 25

						direction = horizontal
 
						#economic_crisis_country
						flowcontainer = {
							spacing = 10
