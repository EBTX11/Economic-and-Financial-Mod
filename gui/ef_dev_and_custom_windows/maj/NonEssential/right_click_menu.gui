				using = action_send_ship_to_retrofit
				enabled = "[IsValid(Ship.ChangeTemplate(ShipTemplate.Self))]"
				onclick = "[Execute(Ship.ChangeTemplate(ShipTemplate.Self))]"
			}
		}

		blockoverride "texture" {
			texture = "gfx/interface/icons/generic_icons/flotillas.dds"
		}

		blockoverride "text" {
			text = "[ShipTemplate.GetNameNoFormatting]"
		}

		blockoverride "right_text" {
			expand = {}

			hbox = {
				margin = { 5 0 }
				spacing = 5
				datamodel = "[ShipTemplate.GetUtilityModifications]"

				item = {
					icon = {
						size = { 28	28 }
						texture = "gfx/interface/buttons/button_icons/plus.dds"
					}
				}
			}

			hbox = {
				margin_right = 10
				spacing = 5
				datamodel = "[ShipTemplate.GetModifications]"

				item = {
					icon = {
						size = { 28	28 }
						texture = "[ShipModificationType.GetIcon]"
					}
				}
			}
		}
	}

	type negotiate_interest_group_button = button {
		using = default_button
		enabled = "[IsValid(Country.StartNegotiationWith(InterestGroup.Self))]"
		onclick = "[Execute(Country.StartNegotiationWith(InterestGroup.Self))]"
		onclick = "[RightClickMenuManager.Close]"

		block "size" {
			size = { 460 44 }
		}

		tooltipwidget = {
			FancyTooltip_IG = {
				blockoverride "ig_pop_info" {}

				blockoverride "leader_and_party_ig_info" {}

				blockoverride "tooltip_content_before" {
					custom_tooltip_textbox = {
						visible = "[Not(StringIsEmpty(GetDesc(Country.StartNegotiationWith(InterestGroup.Self))))]"
						text = "[GetDesc(Country.StartNegotiationWith(InterestGroup.Self))]"
					}

					custom_tooltip_textbox_with_empty_line = {
						text = "NEGOTIATE_LAW_WITH_INTEREST_GROUP"
					}

					custom_tooltip_textbox = {
						text = "NEGOTIATE_LAW_OUTCOME_EFFECTS"
					}

					custom_tooltip_newline = {}
				}
			}
		}

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			margin = { 10 0 }
			spacing = 5

			icon = {
				size = { 28 28 }
				texture = "[InterestGroup.GetTexture]"
			}

			### NAME
			textbox = {
				size = { 180 30 }
				align = nobaseline
				using = elide_fontsize_min
				using = fontsize_large
				text = "[InterestGroup.GetNameNoFormatting]"
			}

			hbox = {
				spacing = 4

				icon = {
					size = { 24 24 }
					texture = "gfx/interface/icons/generic_icons/amenability.dds"
				}

				textbox = {
					autoresize = yes
					align = nobaseline
					using = elide_fontsize_min
					max_width = 30
					raw_text = "#v [InterestGroup.GetAmenability]#!"
				}
			}

			expand = {}

			### CLOUT
			vbox = {
				layoutpolicy_vertical = preferred

				expand = {}

				textbox = {
					layoutpolicy_horizontal = preferred
					size = { 0 20 }
					align = right|nobaseline
					margin_right = 2
					raw_text = "#b [InterestGroup.GetClout|%1]#!"
				}

				bar_horizontal = {
					size = { 150 10 }

					blockoverride "values" {
						min = 0
						max = 1
						value = "[FixedPointToFloat(InterestGroup.GetClout)]"
						invertprogress = yes
					}

					blockoverride "marker_widgetanchor" {
						widgetanchor = left
						mirror = horizontal
					}

					blockoverride "color" {
						color = "[InterestGroup.GetColor]"
					}
				}

				expand = {}
			}
		}
	}

