 SHIP_CONSTRUCTION_SPEED: "@ship_construction![Nbsp][ShipConstruction.GetConstructionSpeed|v] progress each week"
 SHIP_CONSTRUCTION_SPEED_WITH_EFFICIENCY: "[ShipConstruction.GetConstructionSpeed|v] progress each week:#indent_newline:3 \n[ShipConstruction.GetConstructionUsage|v2] from [ShipConstruction.GetCountry.GetAdjectiveNoFlag] [GetBuildingType('building_shipyard').GetName]\n[FactorToMult(ShipConstruction.GetEfficiency)|%+=0] $concept_ship_construction$ Efficiency#!"
 SHIP_CONSTRUCTION_SPEED_BASE_TOOLTIP: "#tooltip_header @ship_construction![Nbsp][concept_ship_construction]#![AddLocalizationIf(Country.IsShipConstructionPaused, 'CONSTRUCTION_IS_PAUSED')]\n#v [Country.GetShipConstruction|0]#! in total\n#v [Country.GetShipConstructionUsage|0]#!/[Country.GetShipConstruction|0] being used\n$TOOLTIP_DELIMITER$\n#v [Country.GetMilitaryConstructionUsageTotal|0]#! used by Military [Concept('concept_ship', '$concept_ships$')]:#indent_newline:3 \n#v [Country.GetMilitaryMaintenanceUsage|0]#! Navy maintenance cost\n#v [Country.GetMilitaryConstructionQueueUsage|0]#! by @ships! #v [Country.GetMilitaryConstructionQueueCount]#! $concept_ships$ under construction#!\n\n#v [Country.GetSupplyConstructionUsageTotal|0]#! used by [Concept('concept_supply_ship', '$concept_supply_ships$')]:#indent_newline:3 \n#v [Country.GetSupplyMaintenanceUsage|0]#! Navy maintenance cost\n#v [Country.GetSupplyConstructionQueueUsage|0]#! by @supply! #v [Country.GetSupplyConstructionQueueCount]#! $concept_supply_ships$ under construction#![ConcatIfNeitherEmpty('\n\n#title Available Ship Construction:#!#indent_newline:3 \n', Country.GetShipConstructionDesc)]#!"
