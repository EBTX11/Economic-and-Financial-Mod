								}
							}
						}
					}
				}
			}

			flowcontainer = {
				visible = "[Or( And( MilitaryFormation.IsArmy, Not(IsDataModelEmpty(MilitaryFormation.AccessCountry.GetAssignedGenerals)) ), And( MilitaryFormation.IsFleet, Not(IsDataModelEmpty(MilitaryFormation.AccessCountry.GetAssignedAdmirals)) ) )]"
				direction = vertical
