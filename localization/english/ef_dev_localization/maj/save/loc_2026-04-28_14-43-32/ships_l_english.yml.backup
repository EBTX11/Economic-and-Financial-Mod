 SUPPLY_SHIPS_TOOLTIP_NO_ARMIES_REQUIRE: "No $concept_armies$ require $concept_supply_ships$"

 ship_type_frigate: "Frigate"
 ship_type_frigate_desc: "A lightly armed sailing ship used for scouting, patrol, and escort duties."
 ship_type_iron_frigate: "Iron Frigate"
 ship_type_iron_frigate_desc: "An iron-hulled evolution of the sailing frigate, this ship combines the traditional roles of the frigate with increased durability and firepower."
 ship_type_ship_of_the_line: "Ship of the Line"
 ship_type_ship_of_the_line_desc: "A large warship designed to operate in the line of battle. The Ship of the Line carries numerous guns on multiple decks."
 ship_type_monitor: "Monitor"
 ship_type_monitor_desc: "A low-profile armored vessel designed for use in coastal waters."
 ship_type_coastal_defense_ship: "Coastal Defense Ship"
 ship_type_coastal_defense_ship_desc: "A heavily armed and armored vessel designed for use in harbors and coastal waters."
 ship_type_destroyer: "Destroyer"
 ship_type_destroyer_desc: "A fast, but heavily armed vessel designed for fleet and escort operations."
 ship_type_aircraft_carrier: "Aircraft Carrier"
 ship_type_aircraft_carrier_desc: "A ship from which airplanes may take off and land, the Aircraft Carrier's duties involve reconnaissance as well as some offensive operations."
 ship_type_torpedo_boat: "Torpedo Boat"
 ship_type_torpedo_boat_desc: "Small, agile vessels designed to deliver devastating strikes on larger, slower warships."
 ship_type_torpedo_boat_destroyer: "Torpedo Boat Destroyer"
 ship_type_torpedo_boat_destroyer_desc: "A vessel designed to counter smaller torpedo boats, while still being capable of launching torpedo attacks themselves."
 ship_type_light_cruiser: "Light Cruiser"
 ship_type_light_cruiser_desc: "Lightly armored cruisers built for long-range patrol, trade protection, and power projection."
 ship_type_armored_cruiser: "Armored Cruiser"
 ship_type_armored_cruiser_desc: "A larger cruiser with a heavy armor belt, capable of engaging most targets save battleships."
 ship_type_protected_cruiser: "Protected Cruiser"
 ship_type_protected_cruiser_desc: "A fast, long-range cruiser with an armored deck protecting its vital components."
 ship_type_seaplane_tender: "Seaplane Tender"
 ship_type_seaplane_tender_desc: "A ship designed to carry and launch seaplanes for reconnaissance and limited offensive operations."
 ship_type_early_ironclad: "Early Ironclad"
 ship_type_early_ironclad_desc: "A powerful ocean-going, steam-powered, and iron-armored vessel."
 ship_type_modern_ironclad: "Modern Ironclad"
 ship_type_modern_ironclad_desc: "An evolution of the traditional ironclad, the modern ironclad incorporates many"
 ship_type_pre_dreadnought: "Pre-Dreadnought"
 ship_type_pre_dreadnought_desc: "A powerful battleship mounting a mixed battery of heavy guns."
 ship_type_dreadnought: "Dreadnought"
 ship_type_dreadnought_desc: "A revolutionary battleship built around a uniform battery of heavy guns."
 ship_type_super_dreadnought: "Super Dreadnought"
 ship_type_super_dreadnought_desc: "An enlarged dreadnought with heavier guns and greater armor."
 ship_type_submarine: "Submarine"
 ship_type_submarine_desc: "A dive-capable vessel primarily intended for use against enemy merchant shipping."
 ship_type_troop_ship: "Troopship"
 ship_type_troop_ship_desc: "A purpose-built supply ship designed to carry men and materiel across the globe."
 ship_type_supply_ship: "Supply Ship"
 ship_type_supply_ship_desc: "A ship that transports military goods from one place to another."

 ship_graphics_type_borodino: "Borodino"
 ship_graphics_type_borodino_desc: "The Borodino class pre-dreadnoughts were the newest battleships in the Russian Imperial Navy at the time of the Russo-Japanese War. Forming the nucleus of Admiral Rozhestvensky's doomed Second Pacific Squadron, four members of the class would be sunk or captured at the Battle of Tsushima."
 ship_graphics_type_mikasa: "Mikasa"
 ship_graphics_type_mikasa_desc: "The flagship of Admiral Tōgō throughout the Russo-Japanese War, the pre-dreadnought battleship Mikasa fought in every major fleet action of the war – becoming an enduring symbol of Japan's naval ascendancy."
 ship_graphics_type_dingyuan: "Dingyuan"
 ship_graphics_type_dingyuan_desc: "The pride of the Beiyang Fleet, the ironclad battleships Dingyuan and Zhenyuan were the most striking symbols of late-Qing military modernization. Fighting valiantly at the Battle of Yalu River, their performance was hampered by the chronic underfunding of the Chinese Imperial Navy."

 ship_group_capital_ships: "Capital Ships"
 ship_group_capital_ships_desc: "Capital ships are the largest, most combat capable ships afloat and are intended for service in the line of battle."

 ship_group_cruisers: "Cruisers"
 ship_group_cruisers_desc: "Cruisers are smaller, more lightly armed vessels intended for long-range cruising operations."

 ship_group_torpedo_craft: "Torpedo Craft"
 ship_group_torpedo_craft_desc: "Torpedo craft are small, agile vessels that rely on the self-propelled torpedo as their main armament."

 ship_group_supply_ships: "Supply Ships"
 ship_group_supply_ships_desc: "Supply ships are the civilian and purpose-built vessels that support and resupply military fleet operations."

