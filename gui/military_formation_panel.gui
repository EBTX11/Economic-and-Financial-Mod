										icon = {
											size = { 20 28 }
											texture = "[CharacterTrait.GetTexture]"
										}
									}	
								}
							}

							hbox = {
								visible = "[Character.IsAdmiral]"
								spacing = 2
								datamodel = "[Character.GetAffectedNavalMissionTypes]"

								item = {
									icon = {
										size = { 25 25 }
										using = tooltip_se
										texture = "[NavalMissionType.GetIcon]"
										tooltip = "ADMIRAL_HAS_BONUS_NAVAL_MISSION_TOOLTIP"
									}
								}
							}

							expand = {}
						}
					}

					expand = {}

					block "additional_info_to_the_right" {
						vbox = {
							layoutpolicy_vertical = expanding

							### Admiral Repairing
							icon = {
								size = { 30 30 }
								visible = "[And( Character.IsAdmiral, Character.IsDefeated )]"
								texture = "[Character.GetRepairingTexture]"
								tooltip = "ADMIRAL_REPAIRING_DATE_TOOLTIP"
							}

							### Travelling Commander
							icon = {
								size = { 30 30 }
								visible = "[Character.IsTravellingToFormation]"
								texture = "gfx/interface/icons/generic_icons/character_busy.dds"
								tooltip = "CHARACTER_IS_TRAVELLING_TO_FORMATION_TOOLTIP"
							}

							expand = {}
						}
					}
				}

				expand = {}
			}
		}

		character_portrait_medium = {
			position = { 0 -5 }
			using = tooltip_se
			blockoverride "highlight" {}
		}
	}

