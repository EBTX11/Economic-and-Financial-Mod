 SET_AS_FLAGSHIP_ON_COOLDOWN: "$concept_flagship$ cannot be changed until [Date.GetString|v]"
 SET_AS_FLAGSHIP_NOT_FLAGSHIP: "[Ship.GetName] is not the $concept_flagship$ of [Ship.GetCountry.GetName]"
 ASSIGN_AS_FLAGSHIP_BUTTON: "Assign as [concept_flagship]"
 ASSIGN_AS_FLAGSHIP_BUTTON_TOOLTIP: "#header Assign as [concept_flagship]#![ConcatIfNeitherEmpty('\n', AddLocalizationIf(Not(IsValid(Ship.AssignAsFlagship)), GetDesc(Ship.AssignAsFlagship)))][ConcatIfNeitherEmpty('\n', AddLocalizationIf(Ship.GetCountry.GetFlagship.IsValid, 'ASSIGN_AS_FLAGSHIP_CONFIRMATION_REPLACING'))]\n$TOOLTIP_DELIMITER$\n$FLAGSHIP_EFFECT_DESC$"
 ASSIGN_AS_FLAGSHIP_CONFIRMATION: "Assign [Ship.GetName] as the [concept_flagship] of [Country.GetName]?[ConcatIfNeitherEmpty('\n\n', AddLocalizationIf(Country.GetFlagship.IsValid, 'ASSIGN_AS_FLAGSHIP_CONFIRMATION_REPLACING'))]\n\n$FLAGSHIP_EFFECT_DESC$\n\n@information! This action can only be done once every [GetDefine('NMilitary', 'FLAGSHIP_CHANGE_COOLDOWN_MONTHS')|v] months"
 ASSIGN_AS_FLAGSHIP_CONFIRMATION_REPLACING: "@warning! [Ship.GetCountry.GetFlagship.GetName] is currently the $concept_flagship$ of [Ship.GetCountry.GetNameNoFormatting]. Assigning a new $concept_flagship$ will replace it."
