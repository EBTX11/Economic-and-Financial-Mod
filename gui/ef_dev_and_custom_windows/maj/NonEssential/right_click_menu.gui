	type build_ship_type_flowcontainer = flowcontainer {
		direction = vertical
		margin = { 5 0 }
		margin_bottom = 5

		background = {
			using = entry_bg_simple
		}

		block "minimumsize" {
			minimumsize = { 360 80 }
		}

		block "ship_type_tooltip" {
			tooltipwidget = {
				FancyTooltip_ShipType = {
					blockoverride "tooltip_content_before" {
						custom_tooltip_textbox = {
							block "construction_command_desc" {
								visible = "[Not(IsValid(ShipTemplate.QueueConstruction))]"
								text = "[GetDesc(ShipTemplate.QueueConstruction)]"
							}
						}

						custom_tooltip_textbox_with_empty_line = {
							text = "SHIP_TEMPLATE_CONSTRUCTION_COST_WITH_LABEL"
						}
					}
				}
			}
		}

		section_header_button = {
			blockoverride "layout" {
				parentanchor = hcenter
				size = { 410 38 }
			}

			blockoverride "left_text" {
				block "selected_ship_template_name" {
					text = "[ShipType.GetNameNoFormatting]"
				}
			}

			blockoverride "right_text" {
				flowcontainer = {
					block "default_template_name_visibility" {}

					textbox = {
						visible = "[ShipTemplate.IsCustom]"
						autoresize = yes
						align = nobaseline
						max_width = 150
						margin_right = 10
						using = elide_fontsize_min
						text = "[ShipTemplate.GetNameNoFormatting]"
					}

					textbox = {
						visible = "[ShipTemplate.IsBase]"
						autoresize = yes
						align = nobaseline
						max_width = 150
						margin_right = 10
						using = elide_fontsize_min
						text = "[concept_base_template]"
					}
				}
			}

			blockoverride "onclick" {
				block "section_header_onclick" {
					onclick = "[GetVariableSystem.Toggle(Concatenate('ship_type_', ShipType.GetIDString))]"
				}
			}

			blockoverride "onclick_showmore" {
				visible = "[Not(GetVariableSystem.Exists(Concatenate('ship_type_', ShipType.GetIDString)))]"
			}

			blockoverride "onclick_showless" {
				visible = "[GetVariableSystem.Exists(Concatenate('ship_type_', ShipType.GetIDString))]"
			}
		}

		widget = {
			size = { 410 52 }

			block "bottom_section_alpha" {}

			hbox = {
				layoutpolicy_horizontal = expanding
				margin = { 5 5 }
				spacing = 5

				block "compact_ship_template"  {
					compact_ship_template = {
						size = { 150 40 }

						blockoverride "button_visibility" {
							visible = no
						}
					}
				}

				### Damage / Armor info
				hbox = {
					margin = { 10 10 }
					spacing = 10

					background = {
						using = dark_area
					}

					textbox = {
						autoresize = yes
						align = nobaseline
						raw_text = "@hull_attack_damage! #v [ShipTemplate.GetModifier.GetValueFor('ship_hull_damage_add')|0]#!"

						block "text_size" {}
					}

					textbox = {
						autoresize = yes
						align = nobaseline
						raw_text = "@ship_armor! #v [ShipTemplate.GetModifier.GetValueFor('ship_armor_add')|0]#!"

						block "text_size" {}
					}
				}

				expand = {}

				flowcontainer = {
					spacing = 5

					### Cancel Construction ship type
					button_icon_minus_action = {
						size = { 28 28 }
						using = fleet_panel_construction_template_build_cancel
						using = tooltip_se

						block "cancel_queue_enabled_and_onclick" {
							tooltip = "CANCEL_SHIP_TEMPLATE_CONSTRUCTION_TOOLTIP"
							enabled = "[IsValid(ShipTemplate.CancelConstruction)]"
							onclick = "[Execute(ShipTemplate.CancelConstruction)]"
						}
					}

					### Start construction of ship type
					button_icon_plus_action = {
						size = { 28 28 }
						using = fleet_panel_construction_template_build

						block "queue_enabled_and_onclick" {
							tooltip = "QUEUE_SHIP_TEMPLATE_CONSTRUCTION_TOOLTIP"
							enabled = "[IsValid(ShipTemplate.QueueConstruction)]"
							onclick = "[Execute(ShipTemplate.QueueConstruction)]"
						}
					}
				}
			}
		}

		flowcontainer = {
			visible = "[GetVariableSystem.Exists(Concatenate('ship_type_', ShipType.GetIDString))]"
			parentanchor = hcenter
			direction = vertical
			datacontext = "[AccessPlayer]"
			datacontext = "[ShipTemplateList]"

			block "datamodel_ship_templates" {
				datamodel = "[ShipTemplateList.GetTemplatesOfType(ShipType.Self)]"
			}

			item = {

				widget = {
					size = { 410 40 }

					hbox = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding
						spacing = 2
						margin_left = 3

						widget = {
							size = { 336 40 }

							tooltipwidget = {
								FancyTooltip_ShipTemplate = {
									blockoverride "tooltip_content_before" {
										custom_tooltip_textbox_fixed_width = {
											visible = "[PdxGuiWidget.HasContext('MilitaryFormation')]"
											text = "[SelectLocalization(ObjectsEqual(ShipTemplate.Self, ShipTemplateList.GetDefaultTemplateForFleetOfType(MilitaryFormation.Self, ShipType.Self).Self), 'SHIP_TEMPLATE_IS_DEFAULT_FOR_FLEET', 'SHIP_TEMPLATE_IS_NOT_DEFAULT_FOR_FLEET')]"
										}

										custom_tooltip_textbox_fixed_width = {
											visible = "[Not(PdxGuiWidget.HasContext('MilitaryFormation'))]"
											text = "[SelectLocalization(ObjectsEqual(ShipTemplate.Self, ShipTemplateList.GetDefaultTemplateOfType(ShipType.Self).Self), 'SHIP_TEMPLATE_IS_DEFAULT', 'SHIP_TEMPLATE_IS_NOT_DEFAULT')]"
										}
									}
								}
							}

							compact_ship_template_button = {
								block "ship_template_selected_visibility" {
									visible = "[Not(ObjectsEqual(ShipTemplate.Self, ShipTemplateList.GetDefaultTemplateOfType(ShipType.Self).Self))]"
								}

								blockoverride "number_minimumsize" {
									minimumsize = { -1 30 }
								}
							}

							widget = {
								size = { 100% 100% }

								block "ship_template_selected_visibility_not" {
									visible = "[ObjectsEqual(ShipTemplate.Self, ShipTemplateList.GetDefaultTemplateOfType(ShipType.Self).Self)]"
								}

								background = {
									using = paper_bg
								}

								ship_template_number_and_name_hbox = {}

								icon = {
									using = highlighted_square_selection
								}
							}
						}

						expand = {}

						button_icon_edit = {
							visible = "[And(ShipTemplate.IsCustom, HasDlcFeature('ship_designer'))]"
							size = { 30 30 }
							using = tooltip_se
							enabled = "[ShipType.HasRequiredTech]"
							onclick = "[PopupManager.ToggleShipDesignerPopupWithTemplate(ShipTemplate.Self)]"
							onclick = "[RightClickMenuManager.Close]"
							tooltip = "SHIP_DESIGNER_EDIT_EXISTING_TEMPLATE"
						}

						button_icon_cancel = {
							visible = "[And(ShipTemplate.IsCustom, HasDlcFeature('ship_designer'))]"
							size = { 30 30 }
							using = tooltip_se
							enabled = "[IsValid(ShipTemplate.DeleteTemplate)]"
							onclick = "[PopupManager.AskConfirmation(ShipTemplate.DeleteTemplate)]"
							tooltip = "SHIP_DESIGNER_DELETE_EXISTING_TEMPLATE"
						}

						textbox = {
							visible = "[And(Not(ShipTemplate.IsCustom), HasDlcFeature('ship_designer'))]"
							autoresize = yes
							align = nobaseline
							text = "pm_base"
						}

						expand = {}
					}
				}
			}
		}
	}

