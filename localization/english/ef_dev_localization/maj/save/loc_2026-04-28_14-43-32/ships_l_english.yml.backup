 SHIP_CONSTRUCTION_MAINTENANCE_HEADER: "Fleet Maintenance"
 SHIP_CONSTRUCTION_MAINTENANCE_TOOLTIP: "#header Fleet Maintenance#!\nYour fleet requires @ship_construction! #v [Country.GetMilitaryMaintenanceDemand|D]#! [concept_ship_construction] weekly for maintenance.\nFulfillment: #v [Country.GetMilitaryMaintenanceFulfillment|%]#!$TOOLTIP_DELIMITER$\nMaintenance is deducted from available [concept_ship_construction] before new construction or repairs.\n[AddLocalizationIf(LessThan_CFixedPoint(Country.GetMilitaryMaintenanceFulfillment, '(CFixedPoint)1'), 'SHIP_CONSTRUCTION_MAINTENANCE_PENALTY_WARNING')]"
 SHIP_CONSTRUCTION_MAINTENANCE_PENALTY_WARNING: "\n#n @warning! Insufficient [concept_ship_construction] for fleet maintenance. Ships are taking weekly hull damage.#!"
 SUPPLY_SHIP_MAINTENANCE_TOOLTIP: "#header Supply Ship Maintenance#!\nYour supply fleet requires @ship_construction! #v [Country.GetSupplyMaintenanceDemand|D]#! supply [concept_ship_construction] weekly for maintenance.\nFulfillment: #v [Country.GetSupplyMaintenanceFulfillment|%]#!$TOOLTIP_DELIMITER$\nMaintenance is deducted from available supply [concept_ship_construction] before new construction.\n[AddLocalizationIf(LessThan_CFixedPoint(Country.GetSupplyMaintenanceFulfillment, '(CFixedPoint)1'), 'SUPPLY_SHIP_MAINTENANCE_PENALTY_WARNING')]"
 SUPPLY_SHIP_MAINTENANCE_PENALTY_WARNING: "\n#n @warning! Insufficient supply [concept_ship_construction] for maintenance. Supply ships are being lost.#!"
 NAVY_MAINTENANCE_COST_LABEL: "@ship_construction! #v [Country.GetTotalMaintenanceDemand|0]#! Navy maintenance cost"
 NAVY_MAINTENANCE_COST_TOOLTIP: "#header Navy maintenance cost#!\n@ship_construction! #v [Country.GetTotalMaintenanceDemand|0]#! in total\n$TOOLTIP_DELIMITER$\n#v [Country.GetMilitaryMaintenanceDemand|0]#! by @ships! #v [Country.GetMilitaryShipCount]#! Military [Concept('concept_ship', '$concept_ships$')]\n#v [Country.GetSupplyMaintenanceDemand|0]#! by @supply! #v [Country.GetTotalSupplyShipCount]#! [Concept('concept_supply_ship', '$concept_supply_ships$')]"

