 SHIP_CONSTRUCTION_TOOLTIP: "#header Construction of [ShipConstruction.GetShipType.GetName]#!\n[ConcatIfNeitherEmpty(AddLocalizationIf(ShipConstruction.IsInProgress, 'SHIP_CONSTRUCTION_WEEKS_LEFT'), '\n')]$TOOLTIP_DELIMITER$\n@ship_construction![Nbsp][ShipConstruction.GetProgress|v0]/[ShipConstruction.GetConstructionCost|v0] [concept_ship_construction] progress ([ShipConstruction.GetProgressPercent|v%])\n[SelectLocalization(EqualTo_CFixedPoint(ShipConstruction.GetEfficiency, '(CFixedPoint)1'), 'SHIP_CONSTRUCTION_SPEED', 'SHIP_CONSTRUCTION_SPEED_WITH_EFFICIENCY')][ConcatIfNeitherEmpty('\n\n', AddLocalizationIf(ShipConstruction.GetFleet.IsValid, 'SHIP_CONSTRUCTION_IN_FLEET'))]"
 SHIP_CONSTRUCTION_WEEKS_LEFT: "[ShipConstruction.GetWeeksLeft|v] week(s) until complete"
