	type military_formation_commander = widget {
		block "widget_size" {
			size = { 370 70 }
		}
		
		widget = {
			parentanchor = vcenter
			position = { 40 0 }
			
			block "button_size" {
				size = { 330 60 }
			}

			button = {
				visible = "[Character.GetCountry.IsLocalPlayer]"
				size = { 100% 100% }
				using = default_button

				block "assign_tooltip" {
					tooltip = "ASSIGN_OR_RECRUIT_CHARACTER"
					using = tooltip_ne
				}

				block "assign_onclick" {
					onclick = "[RightClickMenuManager.ShowForAssignCommander(MilitaryFormation.AccessSelf, PdxGuiWidget.AccessSelf)]"
				}
			}

			widget = {
				visible = "[Not(Character.GetCountry.IsLocalPlayer)]"
				size = { 100% 100% }

				background = {
					using = entry_bg
				}
			}

			vbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				margin_left = 45
				margin_right = 5
				margin_top = 2

				hbox = {
					layoutpolicy_horizontal = expanding

					vbox = {
						layoutpolicy_horizontal = expanding

						hbox = {
							layoutpolicy_horizontal = expanding

					        textbox = {
								layoutpolicy_horizontal = expanding
								size = { 0 25 }
								align = nobaseline
								max_width = 205
								using = elide_fontsize_min
