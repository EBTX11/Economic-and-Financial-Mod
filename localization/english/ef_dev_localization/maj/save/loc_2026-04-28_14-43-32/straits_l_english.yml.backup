l_english:
 DATA_STRAIT_NAME_FORMAT: "#tooltippable_name #tooltip:$TAG$,EMPTY_STRING,StraitTooltip $NAME$#!#!"
 strait_gibraltar: "Strait of Gibraltar"
 strait_bosporus: "Bosporus"
 strait_oresund: "Öresund"
 strait_malacca: "Strait of Malacca"
 strait_hormuz: "Strait of Hormuz"
 strait_bab_el_mandeb: "Bab-el-Mandeb"
 strait_tsugaru: "Tsugaru Strait"
 strait_sunda: "Sunda Strait"
 strait_lombok: "Lombok Strait"
 strait_ombai: "Ombai Strait"

 TOOLTIP_TYPE_STRAIT: "[concept_strait]"
 ALLOWED_COUNTRIES_SHORT_CONCEPT: "[Concept('concept_strait_allowed_countries','$concept_strait_allowed_countries_short$')]"

 building_fortification: "Naval Fortification"
 pmg_base_building_fortification: "Crew Drills"
 pm_fortification: "Regular Crew Drills"

 TOLL_BUDGET_ENTRY: "@money!#variable $VALUE|D$#!: [STATE.GetName] importing #variable $QTY$#! (@money!#variable $GOODS_PRICE|D$#!, total @money!#variable $GOODS_VALUE|D$#!) [GOODS.GetName] through [COUNTRY.GetFlagTextIcon][STRAIT.GetName] with a #variable $TOLL_RATE|%0$#! toll rate"
 TAX_INCOME_TOLLS: "$TAB$#tooltippable #tooltip:[GetPlayer.GetTooltipTag],TOLLS_BREAKDOWN,TariffsTooltip @money![GetPlayer.PredictTolls|D+=]#!#! [concept_tolls]"
 TOLLS_BREAKDOWN: "#tooltip_header [concept_tolls]#!\nTotal: #v @money![GetPlayer.PredictTolls|K+=]#!\n$TOOLTIP_DELIMITER$\n[GetPlayer.PredictTollsDesc]"

 STRAIT_ACCESS_PLAYER: "#b [Strait.GetAccessStatusFor(GetPlayer.Self)]#! [concept_strait_access] for [GetPlayer.GetName] $YOU$"
 STRAIT_TOLLS_PLAYER: "@money!#v [Strait.GetTollsFor(GetPlayer.Self)|D+]#! [concept_tolls] revenue per week"

 #Tolls
 TOLL_RATE_REDUNDANT: "Current toll rate"

 TOLL_RATE_HEADER_no_tolls: "None"
 TOLL_RATE_HEADER_low_tolls: "Low"
 TOLL_RATE_HEADER_medium_tolls: "Medium"
 TOLL_RATE_HEADER_high_tolls: "High"

 STRAIT_NO_TOLLS_TOOLTIP: "#header No [concept_tolls]#![ConcatIfNeitherEmpty(' ', AddLocalizationIf(Strait.StateHasNoTolls(State.Self), 'TAX_OR_EXPENSE_LEVEL_CURRENT'))][ConcatIfNeitherEmpty('\n', GetDesc( Strait.SetControllerTollRateNoTolls( Country.Self )))]\n[SelectLocalization(Strait.StateHasNoTolls(State.Self), 'STRAIT_CURRENT_REVENUE', 'STRAIT_PREDICTED_REVENUE_NO_TOLLS')]"
 STRAIT_LOW_TOLLS_TOOLTIP: "#header Low [concept_tolls]#![ConcatIfNeitherEmpty(' ', AddLocalizationIf(Strait.StateHasLowTolls(State.Self), 'TAX_OR_EXPENSE_LEVEL_CURRENT'))][ConcatIfNeitherEmpty('\n', GetDesc( Strait.SetControllerTollRateLowTolls( Country.Self )))]\n[SelectLocalization(Strait.StateHasLowTolls(State.Self), 'STRAIT_CURRENT_REVENUE', 'STRAIT_PREDICTED_REVENUE_LOW')]"
 STRAIT_MEDIUM_TOLLS_TOOLTIP: "#header Medium [concept_tolls]#![ConcatIfNeitherEmpty(' ', AddLocalizationIf(Strait.StateHasMediumTolls(State.Self), 'TAX_OR_EXPENSE_LEVEL_CURRENT'))][ConcatIfNeitherEmpty('\n', GetDesc( Strait.SetControllerTollRateMediumTolls( Country.Self )))]\n[SelectLocalization(Strait.StateHasMediumTolls(State.Self), 'STRAIT_CURRENT_REVENUE', 'STRAIT_PREDICTED_REVENUE_MEDIUM')]"
 STRAIT_HIGH_TOLLS_TOOLTIP: "#header High [concept_tolls]#![ConcatIfNeitherEmpty(' ', AddLocalizationIf(Strait.StateHasHighTolls(State.Self), 'TAX_OR_EXPENSE_LEVEL_CURRENT'))][ConcatIfNeitherEmpty('\n', GetDesc( Strait.SetControllerTollRateHighTolls( Country.Self )))]\n[SelectLocalization(Strait.StateHasHighTolls(State.Self), 'STRAIT_CURRENT_REVENUE', 'STRAIT_PREDICTED_REVENUE_HIGH')]"

 STRAIT_PREDICTED_REVENUE_NO_TOLLS: "@money!#v [Strait.GetStateTollProfitChangeNoTolls(State.Self)|D+]#! change in revenue from current $concept_tolls$"
 STRAIT_PREDICTED_REVENUE_LOW: "@money!#v [Strait.GetStatePredictedTollProfitLow(State.Self)|D+]#! predicted revenue from [Concept('concept_ship', '$concept_ships$')] passing through [Strait.GetName]\n@money!#v [Strait.GetStateTollProfitChangeLow(State.Self)|D+]#! change in revenue from current $concept_tolls$"
 STRAIT_PREDICTED_REVENUE_MEDIUM: "@money!#v [Strait.GetStatePredictedTollProfitMedium(State.Self)|D+]#! predicted revenue from [Concept('concept_ship', '$concept_ships$')] passing through [Strait.GetName]\n@money!#v [Strait.GetStateTollProfitChangeMedium(State.Self)|D+]#! change in revenue from current $concept_tolls$"
 STRAIT_PREDICTED_REVENUE_HIGH: "@money!#v [Strait.GetStatePredictedTollProfitHigh(State.Self)|D+]#! predicted revenue from [Concept('concept_ship', '$concept_ships$')] passing through [Strait.GetName]\n@money!#v [Strait.GetStateTollProfitChangeHigh(State.Self)|D+]#! change in revenue from current $concept_tolls$"

 STRAIT_CURRENT_REVENUE: "@money!#v [Strait.GetStateTollRevenue(State.Self)|D+]#! current revenue"

 STRAIT_TOLL_TOOLTIP: "#header [Strait.GetName] [concept_tolls]#!\n[SelectLocalization(And( State.GetBuilding('building_naval_fortification').IsValid, Country.IsValid ), 'STRAIT_TOLL_TOOLTIP_ACTIVE', 'STRAIT_TOLL_TOOLTIP_INACTIVE')]"
 STRAIT_TOLL_TOOLTIP_ACTIVE: "[Strait.GetStateTollTextIcon(State.Self)] #b [Strait.GetStateTollStatus(State.Self)]#! ([SelectLocalization(Country.IsLocalPlayer, 'POSITIVE_TOLL', 'NEGATIVE_TOLL')]) $concept_tolls$ collected by [Country.GetName]"
 STRAIT_TOLL_TOOLTIP_INACTIVE: "No $concept_tolls$ are collected by [Country.GetName] due to #b not#! having a [GetBuildingType('building_naval_fortification').GetName]"
 POSITIVE_TOLL: "@money!#v [Strait.GetStateTollProfit(State.Self)|D=+]#!"
 NEGATIVE_TOLL: "@money!#v [Strait.GetStateTollProfit(State.Self)|D=-]#!"

 #Strait Access
 STRAIT_ACCESS_STATUS_open: "Open"
 STRAIT_ACCESS_STATUS_no_military: "No Military"
 STRAIT_ACCESS_STATUS_closed: "Closed"

 STRAIT_ALLOWED_COUNTRIES_STATUS_all: "Everyone"
 STRAIT_ALLOWED_COUNTRIES_STATUS_no_enemies: "No Enemies"
 STRAIT_ALLOWED_COUNTRIES_STATUS_only_allies: "Only Allies"
 STRAIT_ALLOWED_COUNTRIES_STATUS_only_controller: "Only Controller"

 STRAIT_ACCESS_TOOLTIP: "#header [Strait.GetName] [concept_strait_access]#!\n[SelectLocalization( And( State.GetBuilding('building_naval_fortification').IsValid, Country.IsValid ), 'STRAIT_ACCESS_TOOLTIP_ACTIVE', 'STRAIT_ACCESS_TOOLTIP_INACTIVE')]"
 STRAIT_ACCESS_TOOLTIP_ACTIVE: "[Strait.GetStateStraitAccessTextIcon(State.Self)] #b [Strait.GetStateStraitAccessStatus(State.Self)]#! $concept_strait_access$ set by [Country.GetName]\n$TOOLTIP_DELIMITER$\n#title Effects:#! #indent_newline:3 \n[Strait.GetStateStraitAccessStatusDesc(State.Self)]#![ConcatIfNeitherEmpty('\n\n', AddLocalizationIf(Strait.StateStraitAccessIsOverruled(State.Self), 'STRAIT_ACCESS_OVERRIDDEN'))]"
 STRAIT_ACCESS_OVERRIDDEN: "@warning! This $concept_strait_access$ is overruled by the #b [Strait.GetActiveStraitAccessStatus]#! status set by [Strait.GetOtherController(State.Self).GetName]"
 STRAIT_ACCESS_TOOLTIP_INACTIVE: "No $concept_strait_access$ restrictions are enforced by [Country.GetName] due to #b not#! having a [GetBuildingType('building_naval_fortification').GetName]"
 STRAIT_ACCESS_OPEN_TOOLTIP: "#header Open#!\n[ConcatIfNeitherEmpty(' ', AddLocalizationIf(Strait.StateHasAccessOpen(State.Self), 'CURRENT_ACCESS'))][ConcatIfNeitherEmpty('\n', GetDesc( Strait.SetStateAccessOpen( State.Self )))]\nAll [Concept('concept_ship', '$concept_ships$')] may pass through [Strait.GetName]"
 STRAIT_ACCESS_NO_MILITARY_TOOLTIP: "#header No military#!\n[ConcatIfNeitherEmpty(' ', AddLocalizationIf(Strait.StateHasAccessNoMilitary(State.Self), 'CURRENT_ACCESS'))][ConcatIfNeitherEmpty('\n', GetDesc( Strait.SetStateAccessNoMilitary( State.Self )))]\nNo military [Concept('concept_ship', '$concept_ships$')] may pass through [Strait.GetName] except $concept_ships$ from the [concept_strait_allowed_countries]"
 STRAIT_ACCESS_CLOSED_TOOLTIP: "#header Closed#!\n[ConcatIfNeitherEmpty(' ', AddLocalizationIf(Strait.StateHasAccessClosed(State.Self), 'CURRENT_ACCESS'))][ConcatIfNeitherEmpty('\n', GetDesc( Strait.SetStateAccessClosed( State.Self )))]\nNo [Concept('concept_ship', '$concept_ships$')] may pass through [Strait.GetName] except the [concept_strait_allowed_countries]"
 CURRENT_ACCESS: "#i #b (Current $concept_strait_access_short$)#!#!"

 #Strait Allowed Countries
 STRAIT_ALLOWED_COUNTRIES_TOOLTIP: "#header [Strait.GetName] [concept_strait_allowed_countries]#!\n[SelectLocalization( And( State.GetBuilding('building_naval_fortification').IsValid, Country.IsValid ), 'STRAIT_ALLOWED_COUNTRIES_ACTIVE', 'STRAIT_ALLOWED_COUNTRIES_INACTIVE')]"
 STRAIT_ALLOWED_COUNTRIES_ACTIVE: "[Strait.GetStateAllowedCountriesTextIcon(State.Self)] #b [Strait.GetStateAllowedCountriesStatus(State.Self)]#! allowed by [Country.GetName]\n$TOOLTIP_DELIMITER$\n#title Effects:#! #indent_newline:3 \n[Strait.GetStateAllowedCountriesStatusDesc(State.Self)]#!"
 STRAIT_ALLOWED_COUNTRIES_INACTIVE: "No restrictions are enforced by [Country.GetName] due to #b not#! having a [GetBuildingType('building_naval_fortification').GetName]"
 STRAIT_NO_ENEMIES_TOOLTIP: "#header No Enemies#!\n[ConcatIfNeitherEmpty(' ', AddLocalizationIf(Strait.StateHasAllowedCountriesNoEnemies(State.Self), 'TAX_OR_EXPENSE_LEVEL_CURRENT'))][ConcatIfNeitherEmpty('\n', GetDesc( Strait.SetStateAllowedCountriesNoEnemies( State.Self )))]\nThe current [concept_strait_access] (#b [Strait.GetStateStraitAccessStatus(State.Self)]#!) will only apply to [Concept('concept_ship', '$concept_ships$')] from enemies of [Country.GetName]"
 STRAIT_ONLY_ALLIES_TOOLTIP: "#header Only Allies#!\n[ConcatIfNeitherEmpty(' ', AddLocalizationIf(Strait.StateHasAllowedCountriesOnlyAllies(State.Self), 'TAX_OR_EXPENSE_LEVEL_CURRENT'))][ConcatIfNeitherEmpty('\n', GetDesc( Strait.SetStateAllowedCountriesOnlyAllies( State.Self )))]\nOnly allies to [Country.GetName] are exempt from the current [concept_strait_access] restrictions (#b [Strait.GetStateStraitAccessStatus(State.Self)]#!), if any"
 STRAIT_ONLY_CONTROLLER_TOOLTIP: "#header Only [Concept('concept_strait_control', '$concept_strait_controller$')]#!\n[ConcatIfNeitherEmpty(' ', AddLocalizationIf(Strait.StateHasAllowedCountriesOnlyController(State.Self), 'TAX_OR_EXPENSE_LEVEL_CURRENT'))][ConcatIfNeitherEmpty('\n', GetDesc( Strait.SetStateAllowedCountriesOnlyController( State.Self )))]\nOnly [Country.GetName] & [Concept('concept_subject', '$concept_subjects$')] are exempt from the current [concept_strait_access] restrictions (#b [Strait.GetStateStraitAccessStatus(State.Self)]#!), if any"

 STRAIT_NO_CONTROL: "Have at least #v 1#! [Concept('concept_building_level', '$concept_building_level_short$')] of [GetBuildingType('building_naval_fortification').GetName]"
 STRAIT_TOTAL_BLOCK_REQUIRES_FULL_CONTROL: "Requires [Concept('concept_strait_control', '$concept_strait_control$')] of both sides of the [concept_strait]"
 STRAIT_MILITARY_BLOCK_REQUIRES_FULL_CONTROL: "$STRAIT_TOTAL_BLOCK_REQUIRES_FULL_CONTROL$"
 STRAIT_ACCESS_SETTING_REDUNDANT: "Current [concept_strait_access] setting"
 STRAIT_ACCESS_SETTING_NOT_ALLOWED: "#todo PRCAL-44101 Is this error needed?#!"
 TOLL_RATE_NOT_ALLOWED: "#todo PRCAL-44101 Is this error needed?#!"

 STRAIT_STATES_HEADER: "$concept_states$ connected by this $concept_strait$"
 NO_NAVAL_FORTIFICATION_TOOLTIP: "[Country.GetName] has not built a [GetBuildingType('building_naval_fortification').GetName] in [State.GetName] yet and has no control over the [Strait.GetName]"

 #Effects
 STRAIT_ACCESS_OPEN: "All [Concept('concept_ship', '$concept_ships$')] may pass through [Strait.GetName]"
 STRAIT_ACCESS_NO_MILITARY_NO_ENEMIES: "No military [Concept('concept_ship', '$concept_ships$')] from #r enemies#! of [Country.GetName] may pass through [Strait.GetName]"
 STRAIT_ACCESS_NO_MILITARY_ALLIES: "Only military [Concept('concept_ship', '$concept_ships$')] from #g allies#! of [Country.GetName] may pass through [Strait.GetName]"
 STRAIT_ACCESS_NO_MILITARY_ONLY_CONTROLLER: "Only military [Concept('concept_ship', '$concept_ships$')] from [Country.GetName] and its [Concept('concept_subject', '$concept_subjects$')] may pass through [Strait.GetName]"
 STRAIT_ACCESS_CLOSED_NO_ENEMIES: "No [Concept('concept_ship', '$concept_ships$')] from #r enemies#! of [Country.GetName] may pass through [Strait.GetName]"
 STRAIT_ACCESS_CLOSED_ALLIES: "Only [Concept('concept_ship', '$concept_ships$')] from #g allies#! of [Country.GetName] may pass through [Strait.GetName]"
 STRAIT_ACCESS_CLOSED_ONLY_CONTROLLER: "Only [Concept('concept_ship', '$concept_ships$')] from [Country.GetName] and its [Concept('concept_subject', '$concept_subjects$')] may pass through [Strait.GetName]"

 #Trade
 STRAIT_TRADE_HEADER: "[concept_trade] through this [concept_strait]"
 STRAIT_NO_TRADE: "No [concept_trade]"
 STRAIT_TRADE_TOOLTIP: "[StraitPanel.GetTradeBreakdown(Goods.Self)]"
 STRAIT_TRADE_BREAKDOWN: "#header [GOODS.GetName] [concept_trade] through $STRAIT_NAME$#!\nTotal Trade: $TOTAL|v0D$\n$DETAILS$"
 STRAIT_TRADE_BREAKDOWN_ENTRY: "$AMOUNT|v0D$ traded with [STATE.GetOwner.GetFlagTextIcon] [STATE.GetName]"

