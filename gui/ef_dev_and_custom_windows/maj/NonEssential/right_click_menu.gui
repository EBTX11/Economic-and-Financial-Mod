### Bulk change template
right_click_menu = {
	name = "bulk_change_ship_template_right_click_menu"
	parentanchor = right

	blockoverride "title_text" {
		multiline = yes
		max_width = 460
		text = "CURRENT_BULK_SHIP_TEMPLATES_HEADER"
	}

	blockoverride "items" {
		flowcontainer = {
			direction = vertical
			spacing = 5

			### Current Ship Templates
			flowcontainer = {
				direction = vertical
				datamodel = "[ShipSelection.GetTemplatesSelected]"

				item = {
					current_ship_template = {
						blockoverride "template_name" {
							raw_text = "#v [ShipSelection.GetNumShipsSelectedOfTemplate(ShipTemplate.Self)]#! [ShipTemplate.GetNameNoFormatting]"
						}
					}
				}
			}

			widget = {
				size = { 5 5 }
			}

			textbox = {
				datacontext = "[ShipSelection.GetTypeOfShipsSelected]"
				autoresize = yes
				align = nobaseline
				using = elide_fontsize_min
				max_width = 460
				text = "AVAILABLE_BULK_SHIP_TEMPLATES_HEADER"
			}

			### No Available Ship Templates
			textbox = {
				visible = "[IsDataModelEmpty(ShipSelection.GetTemplatesAvailable)]"
				layoutpolicy_horizontal = expanding
				parentanchor = hcenter
				autoresize = yes
				#minimumsize = { 375 -1 }
				using = empty_state_text_properties
				align = hcenter|nobaseline
				margin = { 0 10 }
				text = "NO_AVAILABLE_SHIP_TEMPLATES"
			}

			### Available Ship Templates
			flowcontainer = {
				visible = "[Not(IsDataModelEmpty(ShipSelection.GetTemplatesAvailable))]"
				direction = vertical
				datamodel = "[ShipSelection.GetTemplatesAvailable]"

				item = {
					available_ship_template = {
						blockoverride "onclicks" {
							using = action_send_ship_to_retrofit
							enabled = "[IsValid(ShipSelection.ChangeTemplate(ShipTemplate.Self))]"
							onclick = "[Execute(ShipSelection.ChangeTemplate(ShipTemplate.Self))]"
						}

						blockoverride "template_tooltip" {
							tooltipwidget = {
								FancyTooltip_ShipTemplate = {
									blockoverride "tooltip_content_before" {
										custom_tooltip_textbox = {
											margin_bottom = 5
											text = "BULK_CHANGE_TEMPLATE_TOOLTIP"
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
}

