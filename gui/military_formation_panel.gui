	type military_formation_panel_default_footer = flowcontainer {
		minimumsize = { @panel_width_plus_14 -1 }
		direction = vertical
		spacing = 5
		using = default_fade_in_out

		divider_clean = {
			size = { @panel_width_plus_14 3 }
		}

		background = {
			using = dark_area
		}

		textbox = {
			parentanchor = hcenter
			autoresize = yes
			align = nobaseline
			maximumsize = { @panel_width -1 }
			multiline = yes
			text = "[MilitaryFormation.GetFormationStatusDesc]"
		}

		textbox = {
			visible = "[MilitaryFormation.GetStrategicObjective.IsValid]"
			parentanchor = hcenter
			autoresize = yes
			align = nobaseline
			maximumsize = { @panel_width -1 }
			multiline = yes
			text = "SELECTED_STRATEGIC_OBJECTIVE"
		}

		widget = {
			size = { 5 5 }
		}

		raise_conscripts_button = {
			visible = "[And(And(MilitaryFormation.GetCountry.IsCommittedInDiplomaticPlay, MilitaryFormation.GetCountry.IsLocalPlayer), GreaterThan_int32(MilitaryFormation.GetMaxConscripts, '(int32)0'))]"
			parentanchor = hcenter

			blockoverride "size" {
				size = { 530 60 }
			}
			blockoverride "button_size" {
				size = { 95% 75% }
			}
			blockoverride "mobilization_icon_size" {
				size = { 55 55 }
			}
		}

		flowcontainer = {
			visible = "[And(MilitaryFormation.IsArmy, MilitaryFormation.GetCountry.IsLocalPlayer)]"
			parentanchor = hcenter

			military_formation_mobilize_button = {
				parentanchor = vcenter

				blockoverride "size" {
					size = { 250 60 }
				}
				blockoverride "button_size" {
					size = { 90% 75% }
				}
				blockoverride "mobilization_icon_size" {
					size = { 55 55 }
				}
			}

			widget = {
				size = { 5 5 }
			}

			### TRANSFER UNITS
			button_icon_round = {
				blockoverride "icon_size" { size = { 75% 75% } }
				size = { 55 55 }
				parentanchor = vcenter
				tooltip = "MILITARY_FORMATION_TRANSFER_UNIT_TOOLTIP"
				using = tooltip_ne
				onclick = "[PopupManager.ShowTransferFormation( MilitaryFormation.AccessSelf )]"

				blockoverride "icon" {
					texture = "gfx/interface/icons/formation_order_icons/transfer.dds"
				}
			}

			### INVASION
			button_icon_round_map_interaction = {
				blockoverride "icon_size" { size = { 75% 75% } }
				size = { 55 55 }
				parentanchor = vcenter
				tooltip = "MILITARY_FORMATION_INVASION_TOOLTIP"
				onclick = "[MilitaryFormation.OnInvasionClicked]"
				using = tooltip_ne
				enabled = "[MilitaryFormation.CanInvade]"

				blockoverride "icon" {
					texture = "gfx/interface/icons/formation_order_icons/invasion_land_and_naval.dds"
				}

				action_selection_number = {
					blockoverride "text" {
						text = "[MilitaryFormation.GetNumInvasionSelections|+]"
					}
				}
			}

			### STRATEGIC OBJECTIVE
			button_icon_round_map_interaction = {
				blockoverride "icon_size" { size = { 75% 75% } }
				size = { 55 55 }
				parentanchor = vcenter
				tooltip = "MILITARY_FORMATION_SET_STRATEGIC_OBJECTIVE_TOOLTIP"
				onclick = "[MilitaryFormation.OnSetStrategicObjectiveClicked]"
				using = tooltip_ne

				blockoverride "icon" {
					texture = "gfx/interface/icons/formation_order_icons/strategic_objective.dds"
				}

				action_selection_number = {
					blockoverride "text" {
						text = "[MilitaryFormation.GetNumStrategicObjectiveSelections|+]"
					}
				}

				action_selection_number = {
					parentanchor = right

					blockoverride "position" {
				        position = { -5 0 }
				    }

					blockoverride "text" {
						text = "[MilitaryFormation.GetNumStrategicObjectiveActive|;]"
					}
				}
			}

			### TRANSFER UNITS
			button_icon_round = {
				blockoverride "icon_size" { size = { 75% 75% } }
				size = { 55 55 }
				parentanchor = vcenter
				tooltip = "MOVE_MILITARY_FORMATION"
				using = tooltip_nw
				onclick = "[RightClickMenuManager.ToggleArmyMovement( MilitaryFormation.AccessSelf, PdxGuiWidget.AccessSelf )]"

				blockoverride "icon" {
					texture = "gfx/interface/icons/commander_order_icons/move.dds"
				}
			}
		}

		flowcontainer = {
			visible = "[And(MilitaryFormation.IsFleet, MilitaryFormation.GetCountry.IsLocalPlayer)]"
			spacing = 2
			parentanchor = hcenter

			# edit mission sea regions
			button_icon_round_map_interaction = {
				blockoverride "icon_size" { size = { 75% 75% } }
				size = { 60 60 }
				parentanchor = vcenter
                datacontext = "[MilitaryFormation]" # needed for the tooltip
				tooltip = "EDIT_NAVAL_MISSION_SEA_REGIONS_TOOLTIP"
				onclick = "[MilitaryFormation.OnEditMissionSeaRegionsClicked]"
				enabled = "[MilitaryFormation.CanEditMissionSeaRegions]"
				using = tooltip_above

				blockoverride "icon" {
					texture = "gfx/interface/icons/generic_icons/edit_sea_nodes.dds"
				}
			}

			### INVASION
			button_icon_round_map_interaction = {
				blockoverride "icon_size" { size = { 75% 75% } }
				size = { 60 60 }
				parentanchor = vcenter
				tooltip = "MILITARY_FORMATION_INVASION_TOOLTIP"
				onclick = "[MilitaryFormation.OnInvasionClicked]"
				using = tooltip_above
				enabled = "[MilitaryFormation.CanInvade]"

				blockoverride "icon" {
					texture = "gfx/interface/icons/formation_order_icons/invasion_land_and_naval.dds"
				}

				action_selection_number = {
					blockoverride "text" {
						text = "[MilitaryFormation.GetNumInvasionSelections|+]"
					}
				}
			}

			### TRANSFER UNITS
			button_icon_round = {
				blockoverride "icon_size" { size = { 75% 75% } }
				size = { 60 60 }
				parentanchor = vcenter
				tooltip = "MILITARY_FORMATION_TRANSFER_UNIT_TOOLTIP"
				using = tooltip_above
				onclick = "[PopupManager.ShowTransferFormation( MilitaryFormation.AccessSelf )]"

				blockoverride "icon" {
					texture = "gfx/interface/icons/formation_order_icons/transfer.dds"
				}
			}

			### Naval Mission
			naval_mission_button = {
				blockoverride "toggle_right_click_menu_onclick" {
					onclick = "[RightClickMenuManager.ToggleSelectNavalMissionTypeForFleet(MilitaryFormation.AccessSelf, PdxGuiWidget.AccessSelf)]"
				}
			}
			
			### Move Fleet Menu
			button_icon_round = {
				blockoverride "icon_size" { size = { 75% 75% } }
				size = { 60 60 }
				parentanchor = vcenter
				tooltip = "MOVE_MILITARY_FORMATION"
				onclick = "[RightClickMenuManager.ToggleFleetMovement( MilitaryFormation.AccessSelf, PdxGuiWidget.AccessSelf )]"
				using = tooltip_nw

				blockoverride "icon" {
					texture = "gfx/interface/icons/commander_order_icons/move.dds"
				}
			}
		}

		# FORMATION SETTINGS
		flowcontainer = {
			direction = vertical

			section_header_button = {
				blockoverride "arrow_position" {
					position = { 10 0 }
					parentanchor = left|vcenter
				}

				blockoverride "left_text" {
					text = "FORMATION_SETTINGS"
					fontsize_min = 12
					elide = right
				}

				blockoverride "onclick" {
					onclick = "[GetVariableSystem.Toggle( 'formation_settings' )]"
				}

				blockoverride "onclick_showmore" {
					visible = "[Not(GetVariableSystem.Exists( 'formation_settings' ))]"
				}

				blockoverride "onclick_showless" {
					visible = "[GetVariableSystem.Exists( 'formation_settings' )]"
				}
			}

			flowcontainer = {
				visible = "[GetVariableSystem.Exists( 'formation_settings' )]"
				margin = { 10 10 }
				direction = vertical
				spacing = 5

				textbox = {
					autoresize = yes
					align = nobaseline
					max_width = 500
					fontsize_min = 14
					elide = right
					text = "BORROW_LENDING_SETTING_HEADER"
				}

				dynamicgridbox = {
					datamodel = "[MilitaryFormation.GetBorrowSettings]"

					item = {
						flowcontainer = {
							borrow_lending_setting_option = {
								visible = "[Not(MilitaryFormationBorrowSetting.IsSelected)]"
							}

							borrow_lending_setting_option_selected = {
								visible = "[MilitaryFormationBorrowSetting.IsSelected]"
							}
						}
					}
				}
			}
		}
	}

	type naval_mission_button_small = widget {
		size = { 45 45 }
		using = tooltip_ne
		tooltip = "FLEET_NAVAL_MISSION_BUTTON_TOOLTIP"

		# No Mission - Standby icon
		button_icon_round = {
			visible = "[Not(MilitaryFormation.HasNavalMission)]"
			onclick = "[RightClickMenuManager.ToggleSelectNavalMissionTypeForFleet(MilitaryFormation.AccessSelf, PdxGuiWidget.AccessSelf)]"

			blockoverride "icon" {
				texture = "gfx/interface/icons/commander_order_icons/standby.dds"
			}
		}

		# Mission Icon - All has the same mission
		button_icon_round = {
			visible = "[MilitaryFormation.HasNavalMission]"
			datacontext = "[MilitaryFormation.GetNavalMission.GetType]"
