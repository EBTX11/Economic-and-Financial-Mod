template article_input_fixed_top {
	default_header_clean_faded = {
		size = { 100% 44 }

		blockoverride "text" {
			text = "TREATY_ARTICLE_TYPE_TITLE"
		}
	}

	### Ship Type filters
	flowcontainer = {
		visible = "[ArticleDraft.RequiresInput('ship')]"
		datacontext = "[ArticleDraft.GetShipTypeFilterList]"
		direction = vertical
		parentanchor = hcenter
		spacing = 5
		margin = { 5 5 }

		flowcontainer = {
			spacing = 2
			wrap_count = 4
			datamodel = "[TreatyShipFilterList.GetShipTypeFilters]"

			button = {
				visible = "[TreatyShipFilterList.IsFiltered]"
				size = { 120 40 }
				using = default_button
				onclick = "[TreatyShipFilterList.ResetFilters]"

				textbox = {
					size = { 100% 100% }
					margin = { 5 0 }
					align = hcenter|nobaseline
					using = elide_fontsize_min
					text = "ALL_SHIP_TYPES"
				}
			}

			widget = {
				visible = "[Not(TreatyShipFilterList.IsFiltered)]"
				size = { 120 40 }
				text = "ALL_SHIP_TYPES"

				background = {
					using = paper_bg
				}

				textbox = {
					size = { 100% 100% }
					margin = { 5 0 }
					align = hcenter|nobaseline
					using = elide_fontsize_min
					text = "ALL_SHIP_TYPES"
				}

				icon = {
					using = highlighted_square_selection
				}
			}

			item = {
				compact_ship_template = {
					blockoverride "widget_datacontext" {
						datacontext = "[TreatyShipFilter.GetShipType]"
					}

					size = { 120 40 }

					background = {
						using = dark_area
						alpha = 0.01
					}

					blockoverride "tooltip" {
						tooltip = "TREATY_COMPACT_SHIP_TYPE_TOOLTIP"
					}

					blockoverride "ship_number" {
						raw_text = "#v [TreatyShipFilter.GetNumShipsOfType]#!"
					}

					blockoverride "button_visibility" {
						visible = "[Not(TreatyShipFilter.IsFilterSelected)]"
					}

					blockoverride "highlight_visibility" {
						visible = "[TreatyShipFilter.IsFilterSelected]"
					}

					blockoverride "onclick" {
						onclick = "[TreatyShipFilter.SelectFilter]"
					}
				}
			}
		}

		divider_decorative = {
			parentanchor = hcenter
		}
	}

	goods_filters = {
		visible = "[ArticleDraft.RequiresInput('goods')]"
		parentanchor = hcenter

		blockoverride "staple_icon_selected" {
			visible = "[ArticleDraft.IsSelectedGoods('staple')]"
		}

		blockoverride "staple_icon" {
			visible = "[Not(ArticleDraft.IsSelectedGoods('staple'))]"
		}

		blockoverride "staple_onclick" {
			onclick = "[ArticleDraft.FilterGoods('staple')]"
			using = market_filter_staple_button_sound
		}

		blockoverride "industrial_icon_selected" {
			visible = "[ArticleDraft.IsSelectedGoods('industrial')]"
		}

		blockoverride "industrial_icon" {
			visible = "[Not(ArticleDraft.IsSelectedGoods('industrial'))]"
		}

		blockoverride "industrial_onclick" {
			onclick = "[ArticleDraft.FilterGoods('industrial')]"
			using = market_filter_industrial_button_sound
		}

		blockoverride "luxury_icon_selected" {
			visible = "[ArticleDraft.IsSelectedGoods('luxury')]"
		}

		blockoverride "luxury_icon" {
			visible = "[Not(ArticleDraft.IsSelectedGoods('luxury'))]"
		}

		blockoverride "luxury_onclick" {
			onclick = "[ArticleDraft.FilterGoods('luxury')]"
			using = market_filter_luxury_button_sound
		}

		blockoverride "military_icon_selected" {
			visible = "[ArticleDraft.IsSelectedGoods('military')]"
		}

		blockoverride "military_icon" {
			visible = "[Not(ArticleDraft.IsSelectedGoods('military'))]"
		}

		blockoverride "military_onclick" {
			onclick = "[ArticleDraft.FilterGoods('military')]"
			using = market_filter_military_button_sound
		}
	}

	flowcontainer = {
		visible = "[ArticleDraft.RequiresInput('goods')]"
		parentanchor = hcenter

		widget = {
			parentanchor = vcenter
			size = { 60 30 }

			background = {
				using = entry_bg_simple
			}

			tiny_flag_no_interact = {
				datacontext = "[ArticleDraft.GetFirstOrSource]"
				parentanchor = center
				alwaystransparent = yes
