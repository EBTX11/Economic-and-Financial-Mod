			enabled = "[IsValid(MilitaryFormation.SelectSupplyPriority('low'))]"
			onclick = "[Execute(MilitaryFormation.SelectSupplyPriority('low'))]"
		}
		blockoverride "is_selected_visibility_1" {
			visible = "[MilitaryFormation.IsSupplyPrioritySelected('low')]"
		}
		blockoverride "is_clickable_alpha_1" {
			alpha = "[TransparentIfFalse(IsValid(MilitaryFormation.SelectSupplyPriority('low')))]"
		}

		### Medium Supply Ships Priority
