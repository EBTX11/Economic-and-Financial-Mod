			texture = "gfx/interface/icons/generic_icons/supply_ship_med.dds"
		}
		blockoverride "clicksound_2" {
			using = budget_coins_lvl_2_button_sound
		}
		blockoverride "button_2_click" {
			enabled = "[IsValid(MilitaryFormation.SelectSupplyPriority('medium'))]"
			onclick = "[Execute(MilitaryFormation.SelectSupplyPriority('medium'))]"
		}
		blockoverride "is_selected_visibility_2" {
			visible = "[MilitaryFormation.IsSupplyPrioritySelected('medium')]"
		}
		blockoverride "is_clickable_alpha_2" {
			alpha = "[TransparentIfFalse(IsValid(MilitaryFormation.SelectSupplyPriority('medium')))]"
		}

		### High Supply Ships Priority
		blockoverride "tooltip_3" {
			tooltip = "SUPPLY_PRIORITY_HIGH_TOOLTIP"
		}
		blockoverride "texture_3" {
			texture = "gfx/interface/icons/generic_icons/supply_ship_high.dds"
		}
		blockoverride "clicksound_3" {
			using = budget_coins_lvl_3_button_sound
		}
		blockoverride "button_3_click" {
			enabled = "[IsValid(MilitaryFormation.SelectSupplyPriority('high'))]"
			onclick = "[Execute(MilitaryFormation.SelectSupplyPriority('high'))]"
		}
		blockoverride "is_selected_visibility_3" {
			visible = "[MilitaryFormation.IsSupplyPrioritySelected('high')]"
		}
		blockoverride "is_clickable_alpha_3" {
			alpha = "[TransparentIfFalse(IsValid(MilitaryFormation.SelectSupplyPriority('high')))]"
		}

		blockoverride "visibility_4" {
			visible = no
		}

		blockoverride "visibility_5" {
			visible = no
		}
	}

