 SHIP_REPAIR: "[ShipConstruction.GetShip.GetName] (Repair)"
 SHIP_REPAIR_TOOLTIP: "#header Repair of [ShipConstruction.GetShip.GetName]#!\n[ConcatIfNeitherEmpty(AddLocalizationIf(ShipConstruction.IsInProgress, 'SHIP_CONSTRUCTION_WEEKS_LEFT'), '\n')]$TOOLTIP_DELIMITER$\n@ship_construction![Nbsp][ShipConstruction.GetProgress|v0]/[ShipConstruction.GetConstructionCost|v0] [concept_ship_construction] progress ([ShipConstruction.GetProgressPercent|v%])\n[SelectLocalization(EqualTo_CFixedPoint(ShipConstruction.GetEfficiency, '(CFixedPoint)1'), 'SHIP_CONSTRUCTION_SPEED', 'SHIP_CONSTRUCTION_SPEED_WITH_EFFICIENCY')]\n\nThe ship will return to [ShipConstruction.GetFleet.GetName] once repaired"
 SHIP_RETROFIT: "[ShipConstruction.GetShip.GetName] (Retrofit)"
