									text = "1 [GetPlayer.GetCustom('currency_ISO_4217')] ([GetPlayer.GetCustom('currency_symbol')]) = [GetPlayer.MakeScope.ScriptValue('money_value_prevision_new_currency')|D] @silver!"

									parentanchor = hcenter
									align = hcenter|nobaseline

									elide = left
									default_format = "#white #bold"
									autoresize = yes
									fontsize = 33
									allow_outside = no
									ignoreinvisible = yes
								}
								textbox = {
									text = "(1 [GetPlayer.GetCustom('currency_ISO_4217')] ([GetPlayer.GetCustom('currency_symbol')]) = [GetPlayer.MakeScope.ScriptValue('money_value_prevision_new_currency_in_gold')|D] @gold!)"

									parentanchor = hcenter
									align = hcenter|nobaseline

									elide = left
									default_format = "#white #bold"
									autoresize = yes
									fontsize = 20
									allow_outside = no
									ignoreinvisible = yes
								}
							}

							button_icon_square = {
								name = "currency_introduction"

								#tooltip = "money_value_target_set_x"
								enabled = "[GetScriptedGui('currency_introduction').IsValid( GuiScope.SetRoot(GetPlayer.MakeScope ).End)]"
								onclick = "[GetScriptedGui('currency_introduction').Execute( GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								using = tooltip_below
								parentanchor = hcenter

								size = { 240 40 }
								align = hcenter|nobaseline
								#margin_left = 12
								text = "currency_introduction"
							}
						}
					}
				}
 
				divider_decorative = { }
			} 
		} 
	}
}