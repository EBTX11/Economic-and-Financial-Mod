 UNASSIGN_AS_FLAGSHIP_BUTTON_TOOLTIP: "#header Unassign as [concept_flagship]#!\n$TOOLTIP_DELIMITER$\nUnassign [Ship.GetName] as the $concept_flagship$ of [Ship.GetCountry.GetName].\n\n$FLAGSHIP_EFFECT_DESC$"
 UNASSIGN_AS_FLAGSHIP_CONFIRMATION: "Unassign [Ship.GetName] as the [concept_flagship] of [Country.GetName]?\n\n$FLAGSHIP_EFFECT_DESC$"

