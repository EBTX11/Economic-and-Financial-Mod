				blockoverride "disapproval_visibility" {
					visible = "[LessThan_int32(TreatyDraft.GetArticleTypeAcceptanceWithShip(ArticleType.Self, TreatyDraft.GetRightCountry.Self, Ship.Self), '(int32)0')]"
				}

				blockoverride "undecided_visibility" {
					visible = "[EqualTo_int32(TreatyDraft.GetArticleTypeAcceptanceWithShip(ArticleType.Self, TreatyDraft.GetRightCountry.Self, Ship.Self), '(int32)0')]"
				}
			}
		}
