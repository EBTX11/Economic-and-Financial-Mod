	type ship_header_and_acceptance_icon = widget {
		size = { 100% 40 }

		background = {
			using = dark_area

			modify_texture = {
				using = simple_frame_mask
			}
		}

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			margin = { 10 5 }

			button = {
				visible = "[Ship.IsFlagship]"
				size = { 30 30 }
				alwaystransparent = yes
				texture = "gfx/interface/icons/military_icons/navy_icons/flagship.dds"
			}

			### Ship name
			textbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				align = nobaseline
				using = elide_fontsize_min
				text = "[Ship.GetNameNoFormatting]"
			}

			expand = {}

			flowcontainer = {
				datacontext = "[Ship.GetTemplate]"
				spacing = 2
				margin_right = 10
				datamodel = "[ShipTemplate.GetModifications]"

				item = {
					icon = {
						size = { 24 24 }
						texture = "[ShipModificationType.GetIcon]"
					}
				}
			}

			### ACCEPTANCE ICON - SHIP - NOT SELECTED
			treaty_draft_input_acceptance_button_icon = {
				visible = "[And(Not(PdxGuiWidget.HasContext('WarGoalDraft')), TreatyDraft.GetRightCountry.IsAI)]"

				blockoverride "approval_visibility" {
