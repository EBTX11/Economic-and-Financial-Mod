# Zaibatsu
je_zaibatsu: "The Corporate Empire"
je_zaibatsu_reason: "The rapid industrialization of [ROOT.GetCountry.GetName] has brought much of the economy under the umbrella of the [concept_zaibatsu]. Profiting handsomely from their entanglement with state institutions, these enterprises have become vital organs within the military-industrial structure of #v $JAP$#!.\n\nThe concentrated nature of [ROOT.GetCountry.GetAdjectiveNoFormatting] capital has made the country an international competitor, at the price of placing ever-greater political power in the hands of the Zaibatsu and their military patrons.[SCOPE.GetRootScope.GetCountry.GetCustom('zaibatsu_democracy_snippet')]\n$ZAIBATSU_LIST_HEADER$$ZAIBATSU_LIST_CONTENT$"
je_zaibatsu_complete_header: "To #b cement#! the Zaibatsu:\n"
je_zaibatsu_on_complete_header: "On #b cementing#! the Zaibatsu:\n$EFFECT$"
je_zaibatsu_fail_header: "To #b curtail#! the Zaibatsu:\n"
je_zaibatsu_on_fail_header: "On #b curtailing#! the Zaibatsu:\n$EFFECT$"

zaibatsu_democracy_info: "\n\nWhilst this [concept_journal_entry] is active, [concept_electoral_confidence] will decline by #v 0.5%#! per month"

two_more_more_company_slots_tt: "Can establish more than [SCOPE.ScriptValue('je_zaibatsu_company_slots_threshold')|v0] [Concept('concept_company','$concept_companies$')]"

glossary_zaibatsu: "A #b #italic Zaibatsu#!#! is a family-owned and vertically-integrated industrial and financial conglomerate.\n\nA typical zaibatsu is organized around a holding company and a bank, which hold ownership shares in several, typically industrial, subsidiary companies. The zaibatsu emerged from family merchant congolomerates of the late Edo period, which made use of their pre-existing wealth and ties to the state to consolidate control of much of Japan's industrial base."

country_levels_owned_by_zaibatsu_100_tt: "Greater than [SCOPE.ScriptValue('je_zaibatsu_possible_levels_threshold')|v0] [Concept('concept_building_level','$concept_building_levels$')] are owned by the [concept_zaibatsu] (currently [SCOPE.ScriptValue('country_levels_owned_by_zaibatsu')|v0])"
country_levels_owned_by_zaibatsu_250_tt: "Greater than [SCOPE.ScriptValue('je_zaibatsu_complete_levels_threshold')|v0] [Concept('concept_building_level','$concept_building_levels$')] are owned by the [concept_zaibatsu] (currently [SCOPE.ScriptValue('country_levels_owned_by_zaibatsu')|v0])"
fraction_of_country_levels_owned_by_zaibatsu_ge_to_10_tt: "[Concept('concept_building_level','$concept_building_levels$')] owned by the [concept_zaibatsu] are greater than or equal to [SCOPE.ScriptValue('je_zaibatsu_possible_fraction_threshold')|v%0] of all [ROOT.GetCountry.GetAdjective] $concept_building_levels$ (currently [SCOPE.ScriptValue('fraction_of_country_levels_owned_by_zaibatsu')|v%])"
fraction_of_country_levels_owned_by_zaibatsu_ge_to_25_tt: "[Concept('concept_building_level','$concept_building_levels$')] owned by the [concept_zaibatsu] are greater than or equal to [SCOPE.ScriptValue('je_zaibatsu_complete_fraction_threshold')|v%0] of all [ROOT.GetCountry.GetAdjective] $concept_building_levels$ (currently [SCOPE.ScriptValue('fraction_of_country_levels_owned_by_zaibatsu')|v%])"
