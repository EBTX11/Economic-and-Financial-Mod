im_free_trade_tt: "Has #b not#! $concept_enactment_of_laws_enacted$ any variant of [GetLawType('law_free_trade').GetName]"
im_broken_applicable_treaty_tt: "Has broken a $trade_privilege$, $foreign_investment_rights$, or $law_commitment$ [concept_treaty] with a foreign [concept_country]"

