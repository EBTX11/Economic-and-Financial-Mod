right_click_menu = {
	name = "select_ship_construction_fleet"
	parentanchor = right

	blockoverride "title_text" {
		text = "SELECT_DEFAULT_CONSTRUCTION_FLEET"
	}

	blockoverride "items" {
		flowcontainer = {
			spacing = 10

			flowcontainer = {
				direction = vertical

				button = {
					visible = "[Country.HasDefaultConstructionFleet]"
					using = standard_formation_item_size
					using = default_button
					onclick = "[Execute(Country.ClearDefaultConstructionFleet)]"
					onclick = "[RightClickMenuManager.Close]"
					tooltip = "DEFAULT_SHIP_CONSTRUCTION_IS_NEW_FLEET_TOOLTIP"
					text = "DEFAULT_SHIP_CONSTRUCTION_IS_NEW_FLEET"
				}

				widget = {
					visible = "[Not(Country.HasDefaultConstructionFleet)]"
					using = standard_formation_item_size

					background = {
						using = paper_bg
					}

					textbox = {
						parentanchor = center
						align = nobaseline
						autoresize = yes
						using = elide_fontsize_min
						max_width = 340
						text = "DEFAULT_SHIP_CONSTRUCTION_IS_NEW_FLEET"
					}

					icon = {
						using = highlighted_square_selection
					}
				}

				dynamicgridbox = {
					datamodel = "[AccessPlayer.GetMilitaryFormationsFleet]"

					item = {
						widget = {
							using = standard_formation_item_size

							military_formation_right_click_item = {
								visible = "[Not(MilitaryFormation.IsDefaultConstructionFleet)]"
								enabled = "[IsValid(Country.SetDefaultConstructionFleet( MilitaryFormation.Self ))]"

								blockoverride "default_button_template" {
									using = default_button
								}

								blockoverride "tooltip" {
						        	tooltipwidget = {
										FancyTooltip_MilitaryFormation = {
											blockoverride "tooltip_content_before" {
												custom_tooltip_textbox = {
													visible = "[Not(StringIsEmpty(GetDesc(Country.SetDefaultConstructionFleet(MilitaryFormation.Self))))]"
													text = "[GetDesc(Country.SetDefaultConstructionFleet(MilitaryFormation.Self))]"
												}
											}

											blockoverride "text_before" {
		                        				text =  "SELECT_FLEET_AS_DEFAULT_SHIP_CONSTRUCTION"
		                        				margin_bottom = 15
		                        			}
										}
									}
								}

								blockoverride "onclick" {
									onclick = "[Execute(Country.SetDefaultConstructionFleet( MilitaryFormation.Self ))]"
		                       		onclick = "[RightClickMenuManager.Close]"
								}
							}

							military_formation_right_click_item_selected = {
								visible = "[MilitaryFormation.IsDefaultConstructionFleet]"

								blockoverride "tooltip" {
									tooltipwidget = {
										FancyTooltip_MilitaryFormation = {
											blockoverride "text_before" {
		                        				text =  "CURRENTLY_SELECTED"
		                        				margin_bottom = 15
		                        			}
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
}

### Ship Build Menu - Construction Panel
right_click_menu = {
	name = "build_ship_type_of_group"
	parentanchor = right
	datacontext = "[AccessPlayer]"
	datacontext = "[AccessPlayer.GetShipList]"

	blockoverride "title_text" {}

	blockoverride "scrollarea_margins" {
		margin = { 8 15 }
		margin_top = 0
	}

	blockoverride "scrollarea_maximumsize" {
		maximumsize = { -1 700 }
	}

	blockoverride "resizeparent_without_fixed_bottom" {}

	blockoverride "fixed_top" {
		ship_building_menu_fixed_top = {}
	}

	blockoverride "items" {
		using = default_content_fade
		margin_bottom = 10

		flowcontainer = {
			parentanchor = hcenter
			direction = vertical
			datacontext = "[ShipTemplateList]"

			widget = {
				size = { 5 5 }
			}

			divider_decorative = {}

			widget = {
				size = { 5 5 }
			}

			textbox = {
				visible = "[IsDataModelEmpty(ShipTemplateList.GetTypesAvailableOfGroup(ShipGroup.Self))]"
				parentanchor = hcenter
				autoresize = yes
				minimumsize = { 375 -1 }
				using = empty_state_text_properties
				align = hcenter|nobaseline
				margin = { 0 10 }
				text = "NO_AVAILABLE_SHIP_TYPES"
			}

			### List of ship types in this group
			flowcontainer = {
				spacing = 10
				margin_right = 5
				direction = vertical
				datamodel = "[ShipTemplateList.GetTypesAvailableOfGroup(ShipGroup.Self)]"

				item = {
					flowcontainer = {
						build_ship_type_flowcontainer = {
							visible = "[Country.HasDefaultConstructionFleet]"
							datacontext = "[Country.GetDefaultConstructionFleet]"
							datacontext = "[ShipTemplateList.GetDefaultTemplateForFleetOfType(MilitaryFormation.Self, ShipType.Self)]"

							blockoverride "cancel_queue_enabled_and_onclick" {
								tooltip = "FLEET_CANCEL_SHIP_TEMPLATE_CONSTRUCTION_TOOLTIP"
								enabled = "[IsValid(ShipTemplate.CancelConstructionForFleet(MilitaryFormation.Self))]"
								onclick = "[Execute(ShipTemplate.CancelConstructionForFleet(MilitaryFormation.Self))]"
							}

							blockoverride "queue_enabled_and_onclick" {
								tooltip = "FLEET_SHIP_TEMPLATE_CONSTRUCTION_TOOLTIP"
								enabled = "[IsValid(ShipTemplate.QueueConstructionForFleet(MilitaryFormation.Self))]"
								onclick = "[Execute(ShipTemplate.QueueConstructionForFleet(MilitaryFormation.Self))]"
							}

							blockoverride "ship_template_selected_visibility" {
								visible = "[Not(ObjectsEqual(ShipTemplate.Self, ShipTemplateList.GetDefaultTemplateForFleetOfType(MilitaryFormation.Self, ShipType.Self).Self))]"
							}

							blockoverride "ship_template_selected_visibility_not" {
								visible = "[ObjectsEqual(ShipTemplate.Self, ShipTemplateList.GetDefaultTemplateForFleetOfType(MilitaryFormation.Self, ShipType.Self).Self)]"
							}

							blockoverride "construction_command_desc" {
								visible = "[Not(StringIsEmpty(GetDesc(ShipTemplate.QueueConstructionForFleet(MilitaryFormation.Self))))]"
								text = "[GetDesc(ShipTemplate.QueueConstructionForFleet(MilitaryFormation.Self))]"
							}

							blockoverride "selected_ship_template_name" {
								text = "[ShipType.GetNameNoFormatting]"
							}

							blockoverride "default_template_onclick" {
								enabled = "[IsValid(ShipTemplate.SetAsDefaultForFleet(MilitaryFormation.Self))]"
								onclick = "[Execute(ShipTemplate.SetAsDefaultForFleet(MilitaryFormation.Self))]"
							}

							blockoverride "number_of_ships_of_template" {
								raw_text = "#v [MilitaryFormation.GetShipList.GetNumShipsOfTemplate(ShipTemplate.Self)]#!"
							}

							blockoverride "compact_ship_template"  {
								compact_ship_template = {
									size = { 150 40 }
								}
							}
						}

						build_ship_type_flowcontainer = {
							visible = "[Not(Country.HasDefaultConstructionFleet)]"
							datacontext = "[ShipTemplateList.GetDefaultTemplateOfType(ShipType.Self)]"
						}
					}
				}
			}

			### Unavailable ship types - list
			flowcontainer = {
				visible = "[GetVariableSystem.Exists('unavailable_ship_types')]"
				direction = vertical

				flowcontainer = {
					direction = vertical
					spacing = 10
					margin_right = 5
					datamodel = "[ShipTemplateList.GetTypesUnavailableOfGroup(ShipGroup.Self)]"

					item = {
						flowcontainer = {
							direction = vertical

							build_ship_type_flowcontainer = {
								visible = "[Country.HasDefaultConstructionFleet]"
								datacontext = "[Country.GetDefaultConstructionFleet]"
								datacontext = "[ShipTemplateList.GetDefaultTemplateForFleetOfType(MilitaryFormation.Self, ShipType.Self)]"

								blockoverride "section_header_onclick" {
									enabled = no
								}

								blockoverride "bottom_section_alpha" {
									alpha = 0.3
								}

								blockoverride "default_template_name_visibility" {
									visible = no
								}

								blockoverride "cancel_queue_enabled_and_onclick" {
									tooltip = "FLEET_CANCEL_SHIP_TEMPLATE_CONSTRUCTION_TOOLTIP"
									enabled = "[IsValid(ShipTemplate.CancelConstructionForFleet(MilitaryFormation.Self))]"
									onclick = "[Execute(ShipTemplate.CancelConstructionForFleet(MilitaryFormation.Self))]"
								}

								blockoverride "queue_enabled_and_onclick" {
									tooltip = "FLEET_SHIP_TEMPLATE_CONSTRUCTION_TOOLTIP"
									enabled = "[IsValid(ShipTemplate.QueueConstructionForFleet(MilitaryFormation.Self))]"
									onclick = "[Execute(ShipTemplate.QueueConstructionForFleet(MilitaryFormation.Self))]"
								}

								blockoverride "ship_template_selected_visibility" {
									visible = "[Not(ObjectsEqual(ShipTemplate.Self, ShipTemplateList.GetDefaultTemplateForFleetOfType(MilitaryFormation.Self, ShipType.Self).Self))]"
								}

								blockoverride "ship_template_selected_visibility_not" {
									visible = "[ObjectsEqual(ShipTemplate.Self, ShipTemplateList.GetDefaultTemplateForFleetOfType(MilitaryFormation.Self, ShipType.Self).Self)]"
								}

								blockoverride "construction_command_desc" {
									visible = "[Not(StringIsEmpty(GetDesc(ShipTemplate.QueueConstructionForFleet(MilitaryFormation.Self))))]"
									text = "[GetDesc(ShipTemplate.QueueConstructionForFleet(MilitaryFormation.Self))]"
								}

								blockoverride "selected_ship_template_name" {
									text = "[ShipType.GetNameNoFormatting]"
								}

								blockoverride "default_template_onclick" {
									enabled = "[IsValid(ShipTemplate.SetAsDefaultForFleet(MilitaryFormation.Self))]"
									onclick = "[Execute(ShipTemplate.SetAsDefaultForFleet(MilitaryFormation.Self))]"
								}

								blockoverride "number_of_ships_of_template" {
									raw_text = "#v [MilitaryFormation.GetShipList.GetNumShipsOfTemplate(ShipTemplate.Self)]#!"
								}

								blockoverride "compact_ship_template"  {
									compact_ship_template = {
										size = { 150 40 }

										blockoverride "tooltip" {}

										blockoverride "button_visibility" {
											visible = no
										}
									}
								}
							}

							build_ship_type_flowcontainer = {
								visible = "[Not(Country.HasDefaultConstructionFleet)]"
								datacontext = "[ShipTemplateList.GetDefaultTemplateOfType(ShipType.Self)]"

								blockoverride "section_header_onclick" {
									enabled = no
								}

								blockoverride "bottom_section_alpha" {
									alpha = 0.3
								}

								blockoverride "default_template_name_visibility" {
									visible = no
								}
							}
						}
					}
				}
			}
		}
	}
}

