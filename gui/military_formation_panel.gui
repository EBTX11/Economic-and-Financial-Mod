						size = { 105 30 }
					}

					blockoverride "text" {
						text = "MILITARY_FORMATION_SPEED"
					}

					blockoverride "icon" {
						texture = "gfx/interface/icons/military_icons/navy_icons/speed_navy.dds"
					}
				}

				### BLOCKADE STRENGTH
				small_header_grid_item = {
					tooltip = "MILITARY_FORMATION_BLOCKADE_TOOLTIP"
					alpha = "[TransparentIfZero(MilitaryFormation.GetBlockadeStrengthMax)]"

					blockoverride "small_header_size" {
						size = { 105 30 }
					}

					blockoverride "text" {
						text = "[MilitaryFormation.GetBlockadeStrengthMax|vK]"
					}

					blockoverride "icon" {
						texture = "gfx/interface/icons/military_icons/blockade_strength.dds"
					}

					blockoverride "progressbar" {
						widget = {
							size = { 2 2 }
						}

						white_progressbar_vertical = {
							using = formation_item_progressbar_size
							visible = "[GreaterThanZero_CFixedPoint(MilitaryFormation.GetBlockadeStrengthMax)]"
							blockoverride "values" {
								min = 0
								value = "[FixedPointToFloat(MilitaryFormation.GetBlockadeStrength)]"
								max = "[FixedPointToFloat(MilitaryFormation.GetBlockadeStrengthMax)]"
							}
						}
					}
				}

				### ORGANIZATION
				small_header_grid_item = {
					tooltip = "MILITARY_FORMATION_ORGANIZATION_TOOLTIP"

					blockoverride "small_header_size" {
						size = { 105 30 }
					}

					blockoverride "text" {
						raw_text = "#v [MilitaryFormation.GetOrganizationPercentage|%0]#!"
					}

					blockoverride "icon" {
						texture = "gfx/interface/icons/military_icons/organization.dds"
					}

					blockoverride "progressbar" {
						widget = {
							size = { 2 2 }
						}

						organization_bar = {
							using = formation_item_progressbar_size

							blockoverride "organization_value" {
								value = "[FixedPointToFloat( MilitaryFormation.GetOrganizationPercentage )]"
							}
							blockoverride "organization_color" {
								color = "[GetOrganizationColorVec( MilitaryFormation.GetOrganizationPercentage )]"
							}
						}
					}
				}

				### SCREENING RATIO
				small_header_grid_item = {
					tooltip = "MILITARY_FORMATION_SCREENING_RATIO_TOOLTIP"

					blockoverride "small_header_size" {
						size = { 105 30 }
					}

					blockoverride "text" {
						raw_text = ""
					}

					blockoverride "icon" {
						texture = "gfx/interface/icons/military_icons/navy_icons/screening_vulnerability_ratio.dds"
					}

					blockoverride "textbox" {
						textbox = {
							visible = "[GreaterThanOrEqualTo_CFixedPoint(MilitaryFormation.GetScreeningRatio, '(CFixedPoint)1')]"
							layoutpolicy_horizontal = expanding
							layoutpolicy_vertical = expanding
							using = elide_fontsize_min
							align = right|nobaseline
							raw_text = "#P [MilitaryFormation.GetScreeningRatio|%0]#!"
						}

						textbox = {
							visible = "[Not(GreaterThanOrEqualTo_CFixedPoint(MilitaryFormation.GetScreeningRatio, '(CFixedPoint)1'))]"
							layoutpolicy_horizontal = expanding
							layoutpolicy_vertical = expanding
							using = elide_fontsize_min
							align = right|nobaseline
							raw_text = "#N [MilitaryFormation.GetScreeningRatio|%0]#!"
						}
					}
				}

				### INVOLVEMENT
				small_header_grid_item = {
					tooltip = "MILITARY_FORMATION_INVOLVEMENT_TOOLTIP"

					blockoverride "small_header_size" {
						size = { 105 30 }
					}

					blockoverride "text" {
						raw_text = "#v [MilitaryFormation.GetInvolvementGenerated|K]#!"
					}

					blockoverride "icon" {
						texture = "gfx/interface/icons/commander_order_icons/project_power.dds"
					}

					blockoverride "icon_size" {
						size = { 90% 90% }
					}
				}

			}
		}
	}

	type military_formation_icon_and_bars = widget {
		block "military_formation_icon_and_bars_size" {
			size = { 220 80 }
		}

		flowcontainer = {
			parentanchor = vcenter|right
			direction = vertical
			#spacing = 2

			block "datacontext" {
				datacontext = "[MilitaryFormation.GetShipList]"
			}
			
			background = {
				using = simple_frame
				margin = { 3 3 }
			}

			bar_horizontal_with_background = {
				parentanchor = right

				block "first_bar_tooltip" {
					tooltip = "MILITARY_FORMATION_HIT_POINTS_TOOLTIP"
				}

				block "first_bar_size" {
					size = { 165 25 }
				}

				blockoverride "frame_texture_density" {
					texture_density = 4
				}

				blockoverride "values" {
					block "first_bar_values" {
						min = 0
						max = 1
						value = "[FixedPointToFloat(ShipList.GetHitPointsPercentage)]"
					}
				}

				textbox = {
					margin = { 5 0 }
					autoresize = yes
					align = nobaseline
					
					block "text_parentanchor" {
						parentanchor = vcenter|right
					}

					block "first_bar_text" {
						raw_text = "@ship_hp! #b [ShipList.GetHitPointsPercentage|0%]#!"
					}
				}

				blockoverride "color" {
					using = color_green_approval
				}
			}

			bar_horizontal_with_background = {
				parentanchor = right

				block "second_bar_tooltip" {
					tooltip = "MILITARY_FORMATION_CREW_TOOLTIP"
				}

				block "second_bar_size" {
					size = { 148 18 }
				}

				blockoverride "frame_texture_density" {
					texture_density = 4
				}

				blockoverride "values" {
					block "second_bar_values" {
						min = 0
						max = "[ShipList.GetCrewMax]"
						value = "[ShipList.GetCrew]"
					}
				}

				textbox = {
					margin = { 5 0 }
					autoresize = yes
					align = nobaseline
					using = fontsize_small

					block "text_parentanchor" {
						parentanchor = vcenter|right
					}

					block "second_bar_text" {
						raw_text = "@crew! #b [MilitaryFormation.GetShipList.GetCrew|D]#! / [ShipList.GetCrewMax|D]"
					}
				}

				blockoverride "color" {
					using = color_blue_negative
				}
			}

			bar_horizontal_with_background = {
				parentanchor = right
				alwaystransparent = no
				onmousehierarchyenter = "[AccessHighlightManager.HighlightMilitaryFormationSupplyNetwork(MilitaryFormation.Self)]"
				onmousehierarchyleave = "[AccessHighlightManager.RemoveHighlight]"

				block "third_bar_tooltip" {
					tooltip = "MILITARY_FORMATION_SUPPLY_TOOLTIP"
				}

				block "third_bar_size" {
					size = { 165 18 }
				}

				blockoverride "frame_texture_density" {
					texture_density = 4
				}

				blockoverride "values" {
					block "third_bar_values" {
						min = 0
						max = "[MilitaryFormation.GetSupplyCapacity]"
						value = "[MilitaryFormation.GetSupplyRaw]"
					}
				}

				textbox = {
					margin = { 5 0 }
					autoresize = yes
					align = nobaseline
					using = fontsize_small

					block "text_parentanchor" {
						parentanchor = vcenter|right
					}

					block "third_bar_text" {
						raw_text = "@ship_supplies! #b [MilitaryFormation.GetSupplyRaw|D]#! / [MilitaryFormation.GetSupplyCapacity|D]#!"
					}
				}

				blockoverride "color" {
					using = color_gold_positive
				}
			}
		}

		block "entire_icon" {
			widget = {
				block "icon_size" {
					size = { 80 80 }
				}

				# Background
				block "icon_background" {
					icon = {
						size = { 100% 100% }
						texture = "gfx/interface/backgrounds/round_button_bg.dds"
					}
				}

				# The icon as a button to customize
				button = {
					visible = "[MilitaryFormation.GetCountry.IsLocalPlayer]"
					size = { 100% 100% }
					onclick = "[PopupManager.ShowMilitaryFormationChangeName(MilitaryFormation.Self)]"

					button = {
						parentanchor = center
						size = { 85% 85% }
						alwaystransparent = yes
						color = "[MilitaryFormation.GetFlagColor]"

						block "icon" {
							texture = "[MilitaryFormation.GetFlag]"
						}
					}
				}

				# Only the icon, no button to customize
				icon = {
					visible = "[Not(MilitaryFormation.GetCountry.IsLocalPlayer)]"
					parentanchor = center
					size = { 75% 75% }
					color = "[MilitaryFormation.GetFlagColor]"

					block "icon" {
						texture = "[MilitaryFormation.GetFlag]"
					}
				}
			}
		}
	}

